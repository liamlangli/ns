mod std

// libc
ref fn print(fmt: str) void
ref fn open(path: str, mode: str) u64
ref fn read(fd: u64) str
ref fn write(fd: u64, buf: str) u64

// libm
ref fn sqrt(x: f64) f64

// string (str is utf8-encoded; substr indexes bytes, utf8_len counts codepoints)
ref fn substr(s: str, start: i32, len: i32) str
ref fn unescape(s: str) str
ref fn utf8_len(s: str) i32