{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nano Script",
    "scopeName": "source.ns",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#function-definition" },
        { "include": "#type-definition" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.ns",
                    "begin": "//",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.comment.ns" }
                    },
                    "end": "$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.ns",
                    "begin": "\"",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.ns" }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.ns" }
                    },
                    "patterns": [
                        { "include": "#string-escape" }
                    ]
                },
                {
                    "name": "string.quoted.single.ns",
                    "begin": "'",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.ns" }
                    },
                    "end": "'",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.ns" }
                    },
                    "patterns": [
                        { "include": "#string-escape" }
                    ]
                },
                {
                    "name": "string.interpolated.ns",
                    "begin": "`",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.ns" }
                    },
                    "end": "`",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.ns" }
                    },
                    "patterns": [
                        { "include": "#string-escape" },
                        { "include": "#string-interpolation" }
                    ]
                }
            ]
        },
        "string-escape": {
            "name": "constant.character.escape.ns",
            "match": "\\\\."
        },
        "string-interpolation": {
            "name": "meta.interpolation.ns",
            "begin": "\\{",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.ns" }
            },
            "end": "\\}",
            "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.ns" }
            },
            "patterns": [
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#function-call" },
                { "include": "#operators" },
                { "include": "#punctuation" },
                { "include": "#identifiers" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.ns",
                    "match": "\\b(if|else|for|in|to|loop|do|break|continue|return|match|await)\\b"
                },
                {
                    "name": "keyword.declaration.ns",
                    "match": "\\b(fn|let|const|struct|type|mod|use|ref|ops|kernel|async)\\b"
                },
                {
                    "name": "keyword.operator.word.ns",
                    "match": "\\b(as|assert)\\b"
                },
                {
                    "name": "keyword.other.ns",
                    "match": "\\b(default)\\b"
                },
                {
                    "name": "constant.language.boolean.ns",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.nil.ns",
                    "match": "\\b(nil)\\b"
                }
            ]
        },
        "types": {
            "name": "storage.type.primitive.ns",
            "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|str|void|any)\\b"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.ns",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.ns",
                    "match": "\\b0b[01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.ns",
                    "match": "\\b0o[0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.ns",
                    "match": "\\b\\d+\\.\\d+f?\\b|(?<=[^\\w.]|^)\\.\\d+f?\\b|\\b\\d+f\\b"
                },
                {
                    "name": "constant.numeric.integer.ns",
                    "match": "\\b\\d+[iub]?\\b"
                }
            ]
        },
        "function-definition": {
            "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.fn.ns" },
                "2": { "name": "entity.name.function.ns" }
            }
        },
        "type-definition": {
            "match": "\\b(struct|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.ns" },
                "2": { "name": "entity.name.type.ns" }
            }
        },
        "function-call": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.call.ns" }
            }
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.compound.ns",
                    "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.comparison.ns",
                    "match": "(===|!==|==|!=|<=|>=)"
                },
                {
                    "name": "keyword.operator.logical.ns",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.shift.ns",
                    "match": "(<<|>>)"
                },
                {
                    "name": "keyword.operator.arrow.ns",
                    "match": "(->)"
                },
                {
                    "name": "keyword.operator.comparison.ns",
                    "match": "(<|>)"
                },
                {
                    "name": "keyword.operator.assignment.ns",
                    "match": "(=)"
                },
                {
                    "name": "keyword.operator.arithmetic.ns",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.bitwise.ns",
                    "match": "(&|\\||\\^|~)"
                },
                {
                    "name": "keyword.operator.ternary.ns",
                    "match": "(\\?)"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.comma.ns",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.colon.ns",
                    "match": ":"
                },
                {
                    "name": "punctuation.accessor.dot.ns",
                    "match": "\\."
                },
                {
                    "name": "punctuation.section.braces.ns",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.section.parens.ns",
                    "match": "[()]"
                },
                {
                    "name": "punctuation.section.brackets.ns",
                    "match": "[\\[\\]]"
                }
            ]
        },
        "identifiers": {
            "name": "variable.other.ns",
            "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
    }
}
