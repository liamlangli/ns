{
    "name": "nslang",
    "displayName": "Nano Script",
    "description": "Nano Script language support, including project run and build commands.",
    "version": "0.1.3",
    "publisher": "liamlangli",
    "license": "MIT",
    "icon": "icons/ns.png",
    "main": "./extension.js",
    "scripts": {
        "pack": "cp ../../README.md README.md && cp ../../LICENSE LICENSE && vsce package"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/liamlangli/ns"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ns",
                "aliases": [
                    "Nano Script",
                    "ns",
                    "nslang"
                ],
                "extensions": [
                    ".ns"
                ],
                "icon": {
                    "light": "./icons/ns.svg",
                    "dark": "./icons/ns.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ns",
                "scopeName": "source.ns",
                "path": "./syntaxes/ns.tmLanguage.json"
            }
        ],
        "themes": [
            {
                "label": "Nano Script",
                "uiTheme": "vs-dark",
                "path": "./themes/nanoscript-color-theme.json"
            }
        ],
        "commands": [
            {
                "command": "nslang.run",
                "title": "Run Project",
                "category": "Nano Script",
                "icon": "$(play)"
            },
            {
                "command": "nslang.build",
                "title": "Build Project",
                "category": "Nano Script",
                "icon": "$(tools)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "nslang.run",
                    "when": "resourceLangId == ns",
                    "group": "navigation@1"
                },
                {
                    "command": "nslang.build",
                    "when": "resourceLangId == ns",
                    "group": "navigation@2"
                }
            ]
        },
        "configuration": {
            "title": "Nano Script",
            "properties": {
                "nslang.executablePath": {
                    "type": "string",
                    "default": "ns",
                    "scope": "resource",
                    "description": "Path or command name for the Nano Script executable used by Run Project and Build Project."
                }
            }
        },
        "configurationDefaults": {
            "files.associations": {
                "**/ns.mod": "toml"
            }
        }
    }
}
