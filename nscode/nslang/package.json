{
    "name": "nslang",
    "displayName": "Nano Script",
    "description": "Syntax highlighting for the Nano Script (ns) language.",
    "version": "0.2.0",
    "publisher": "liamlangli",
    "license": "MIT",
    "icon": "icons/ns.png",
    "scripts": {
        "pack": "cp ../../README.md README.md && cp ../../LICENSE LICENSE && vsce package"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/liamlangli/ns"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ns",
                "aliases": [
                    "Nano Script",
                    "ns",
                    "nslang"
                ],
                "extensions": [
                    ".ns"
                ],
                "icon": {
                    "light": "./icons/ns.svg",
                    "dark": "./icons/ns.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ns",
                "scopeName": "source.ns",
                "path": "./syntaxes/ns.tmLanguage.json"
            }
        ],
        "themes": [
            {
                "label": "Nano Script",
                "uiTheme": "vs-dark",
                "path": "./themes/nanoscript-color-theme.json"
            }
        ],
        "configurationDefaults": {
            "files.associations": {
                "**/ns.mod": "toml"
            }
        }
    }
}
