use std

assert ns_run("println(42)") == "42\n"
assert ns_run("fn add(a: i32, b: i32) i32 { return a + b }\nprintln(add(19, 23))") == "42\n"
assert ns_run("let sum = 0\nfor value in 1 to 5 { sum = sum + value }\nprintln(sum)") == "10\n"
assert ns_run("fn fib(n: i32) i32 { if n < 2 { return n } return fib(n - 1) + fib(n - 2) }\nprintln(fib(8))") == "21\n"
assert ns_run("let name = \"Nano\"\nprintln(`hello {name}`)") == "hello Nano\n"

let spans = ns_highlight("let answer: i32 = 42 // result")
assert spans.len > 0
assert ns_diagnostics("if true { println(1)").len > 0

print("nscode wasm backend tests passed\n")
