// Headless tests for the native Code view workspace model.
//
//   bin/ns run nscode/native/workspace_test.ns

use std
use editor
use workspace
use os

let g_fail = 0

fn check(name: str, ok: bool) {
    if ok {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + unescape("\n"))
    }
}

fn main() i32 {
    check("workspace scans", workspace_init())
    check("workspace defaults to project root", g_workspace_root == ".")
    check("workspace has files", g_workspace_count > 0)
    check("gitignored bin directory is hidden", workspace_find("bin") < 0)
    check("git metadata is hidden", workspace_find(".git") < 0)
    check("main is initially active", os_entry_name(g_workspace_active) == "main.ns")
    check("main source is loaded", g_doc.len > 0)

    let main_index = g_workspace_active
    check("initial file has a tab", g_workspace_tab_count == 1 && g_workspace_tabs[0] == main_index)
    let editor_index = workspace_find("editor.ns")
    check("editor file is discovered", editor_index >= 0)
    check("binary asset is discovered", workspace_find("icon.png") >= 0)
    check("binary asset is not editable", workspace_entry_editable(workspace_find("icon.png")) == false)

    place_cursor(0, 0, false)
    insert_str(unescape("// unsaved\n"))
    check("active edit is dirty", workspace_entry_dirty(main_index))
    check("switches to editor", workspace_open(editor_index))
    check("opening a file adds a tab", g_workspace_tab_count == 2 && g_workspace_tabs[1] == editor_index)
    check("editor source is loaded", g_doc.len > 0)
    check("newly loaded editor is clean", workspace_entry_dirty(editor_index) == false)
    check("switches back to main", workspace_open(main_index))
    check("unsaved main edit survives switch", line_text(0) == "// unsaved")
    check("main edit can undo after switch", undo())
    check("main undo restores original", line_text(0) != "// unsaved")
    check("switches to editor after undo", workspace_open(editor_index))
    check("editor has separate undo history", can_undo() == false)
    check("switches back to main redo branch", workspace_open(main_index))
    check("main redo survives file switches", redo())
    check("main redo restores edit", line_text(0) == "// unsaved")
    workspace_close_tab(main_index)
    check("closing active tab selects neighbor", g_workspace_tab_count == 1 && g_workspace_active == editor_index)

    if g_fail == 0 {
        print("workspace_test: all passed" + unescape("\n"))
    } else {
        print("workspace_test: " + itos(g_fail) + " FAILED" + unescape("\n"))
    }
    assert g_fail == 0
    return g_fail
}
