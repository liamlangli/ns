// Global Settings persistence round trip. The store is redirected to the
// platform temp directory so the user's real preferences remain untouched.

use std
use os
use editor
use workspace
use render

let g_fail = 0

fn check(name: str, ok: bool) {
    if ok {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + unescape("\n"))
    }
}

fn main() i32 {
    let temp = os_env("TMPDIR")
    if temp == "" {
        temp = os_env("TEMP")
    }
    if temp == "" {
        temp = "."
    }
    g_settings_root_override = temp + "/nscode_native_settings_test"
    g_settings_persist = true
    g_setting_font_family = 0
    g_setting_font_size = 2
    g_setting_theme = 1
    g_setting_language = 2
    set_syntax_language(2)

    check("settings save", settings_save())
    check("settings file exists", os_file_size(settings_path()) > 0)

    g_setting_font_family = 1
    g_setting_font_size = 1
    g_setting_theme = 0
    g_setting_language = 0
    set_syntax_language(0)
    check("settings load", settings_load())
    check("font family reloads", g_setting_font_family == 0)
    check("font size reloads", g_setting_font_size == 2)
    check("theme reloads", g_setting_theme == 1)
    check("language reloads", g_setting_language == 2)
    check("language syncs tokenizer", g_syntax_language == 2)

    if g_fail == 0 {
        print("settings_test: all passed" + unescape("\n"))
    } else {
        print("settings_test: " + itos(g_fail) + " FAILED" + unescape("\n"))
    }
    assert g_fail == 0
    return g_fail
}
