// `nanoscript` is the native editor's default syntax highlight. Its core
// palette uses the ns green (#61d394) and pure white at different brightness
// levels, with yellow-green reserved for string literals.
fn col_nanoscript_green() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#087a4a")
    }
    return ui_pack_color("#61d394")
}
fn col_nanoscript_green_bright() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#096b43")
    }
    return ui_pack_color("#6be8a3")
}
fn col_nanoscript_yellow_green() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#68751f")
    }
    return ui_pack_color("#b7dc6f")
}
fn col_nanoscript_white() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#202832")
    }
    return ui_pack_color("#e1e1e1")
}
fn col_nanoscript_white_dim() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#46515c")
    }
    return ui_pack_color("#a6a6a6")
}
fn col_nanoscript_white_deep() u32 {
    if g_setting_theme == 1 {
        return ui_pack_color("#7a8490")
    }
    return ui_pack_color("#737373")
}

fn nanoscript_token_color(kind: i32) u32 {
    if kind == TK_KEYWORD() {
        return col_nanoscript_green_bright()
    }
    if kind == TK_TYPE() {
        return col_nanoscript_green()
    }
    if kind == TK_NUMBER() {
        return col_nanoscript_white()
    }
    if kind == TK_CONSTANT() {
        return col_nanoscript_white()
    }
    if kind == TK_STRING() {
        return col_nanoscript_yellow_green()
    }
    if kind == TK_COMMENT() {
        return col_nanoscript_white_deep()
    }
    if kind == TK_PUNCT() {
        return col_nanoscript_white_dim()
    }
    if kind == TK_CALL() {
        return col_nanoscript_white()
    }
    return col_nanoscript_white_dim()
}

fn token_color(kind: i32) u32 {
    if g_setting_language == 1 {
        if kind == TK_KEYWORD() {
            return col_blue()
        }
        if kind == TK_TYPE() {
            return ui_pack_color("#4ec9b0")
        }
        if kind == TK_STRING() {
            return ui_pack_color("#ce9178")
        }
        if kind == TK_COMMENT() {
            return ui_pack_color("#6a9955")
        }
        if kind == TK_NUMBER() {
            return ui_pack_color("#b5cea8")
        }
        if kind == TK_CALL() {
            return ui_pack_color("#dcdcaa")
        }
        return col_text()
    }
    if g_setting_language == 2 {
        if kind == TK_KEYWORD() {
            return col_yellow()
        }
        if kind == TK_TYPE() {
            return col_blue()
        }
        if kind == TK_STRING() {
            return ui_pack_color("#a8d08d")
        }
        if kind == TK_COMMENT() {
            return col_muted()
        }
        if kind == TK_NUMBER() {
            return ui_pack_color("#c6a0f6")
        }
        if kind == TK_CALL() {
            return ui_pack_color("#8aadf4")
        }
        return col_text()
    }
    return nanoscript_token_color(kind)
}

// Minimap syntax colors mirror the main nanoscript palette at a uniform 50%
// alpha so the dense fill-rect field stays subordinate to the source text.
fn minimap_token_color(kind: i32) u32 {
    if g_setting_language == 1 {
        if kind == TK_KEYWORD() {
            return ui_pack_rgba_floats(0.25, 0.55, 0.95, 0.5)
        }
        if kind == TK_TYPE() {
            return ui_pack_rgba_floats(0.31, 0.79, 0.69, 0.5)
        }
        if kind == TK_STRING() {
            return ui_pack_rgba_floats(0.81, 0.57, 0.47, 0.5)
        }
    }
    if g_setting_language == 2 {
        if kind == TK_KEYWORD() {
            return ui_pack_rgba_floats(0.95, 0.79, 0.42, 0.5)
        }
        if kind == TK_TYPE() {
            return ui_pack_rgba_floats(0.48, 0.66, 1.0, 0.5)
        }
        if kind == TK_STRING() {
            return ui_pack_rgba_floats(0.66, 0.82, 0.55, 0.5)
        }
    }
    if kind == TK_KEYWORD() {
        return ui_pack_rgba_floats(0.42, 0.91, 0.64, 0.5)
    }
    if kind == TK_TYPE() {
        return ui_pack_rgba_floats(0.38, 0.83, 0.58, 0.5)
    }
    if kind == TK_STRING() {
        return ui_pack_rgba_floats(0.72, 0.86, 0.44, 0.5)
    }
    if kind == TK_COMMENT() {
        return ui_pack_rgba_floats(0.45, 0.45, 0.45, 0.5)
    }
    if kind == TK_NUMBER() {
        return ui_pack_rgba_floats(0.88, 0.88, 0.88, 0.5)
    }
    if kind == TK_CONSTANT() {
        return ui_pack_rgba_floats(0.88, 0.88, 0.88, 0.5)
    }
    if kind == TK_CALL() {
        return ui_pack_rgba_floats(0.88, 0.88, 0.88, 0.5)
    }
    return ui_pack_rgba_floats(0.65, 0.65, 0.65, 0.5)
}

fn clear_color() ui_color_rgba {
    if g_setting_theme == 1 {
        return ui_color_rgba { r: 0.957, g: 0.965, b: 0.973, a: 1.0 }
    }
    if g_setting_theme == 2 {
        return ui_color_rgba { r: 0.0, g: 0.0, b: 0.0, a: 1.0 }
    }
    return ui_color_rgba { r: 0.071, g: 0.078, b: 0.090, a: 1.0 }
}

fn setting_language_label() str {
    if g_setting_language == 1 {
        return "TypeScript"
    }
    if g_setting_language == 2 {
        return "Python"
    }
    return "Nano Script"
}

fn setting_theme_label() str {
    if g_setting_theme == 1 {
        return "Light"
    }
    if g_setting_theme == 2 {
        return "High Contrast"
    }
    return "Dark"
}

fn settings_home() str {
    if g_settings_root_override != "" {
        return g_settings_root_override
    }
    let home = os_env("HOME")
    if home == "" {
        home = os_env("USERPROFILE")
    }
    if home == "" {
        home = os_cwd()
    }
    return home
}

fn settings_dir() str {
    return settings_home() + "/.ns/nscode"
}

fn settings_path() str {
    return settings_dir() + "/settings.db"
}

fn settings_save() bool {
    if g_settings_persist == false {
        return true
    }
    if os_make_dirs(settings_dir()) == 0 {
        return false
    }
    let data = "NSSET1|" + itos(g_setting_font_family) + "|" + itos(g_setting_font_size) + "|" + itos(g_setting_theme) + "|" + itos(g_setting_language)
    let fd = open(settings_path(), "wb")
    if fd == 0 {
        return false
    }
    write(fd, data)
    close(fd)
    return true
}

fn settings_load() bool {
    g_settings_loaded = true
    let fd = open(settings_path(), "rb")
    if fd == 0 {
        return false
    }
    let data = read(fd)
    close(fd)
    if data.len < 14 {
        return false
    }
    if substr(data, 0, 6) != "NSSET1" {
        return false
    }
    g_setting_font_family = clamp_i(byte_at(data, 7) - 48, 0, 1)
    g_setting_font_size = clamp_i(byte_at(data, 9) - 48, 0, 2)
    g_setting_theme = clamp_i(byte_at(data, 11) - 48, 0, 2)
    g_setting_language = clamp_i(byte_at(data, 13) - 48, 0, 2)
    set_syntax_language(g_setting_language)
    return true
}

fn clamp(v: f64, lo: f64, hi: f64) f64 {
    if v < lo {
        return lo
    }
    if v > hi {
        return hi
    }
    return v
}

fn scroll_max(content_h: f64, body_h: f64) f64 {
    if content_h > body_h {
        return content_h - body_h
    }
    return 0.0
}

fn raw_hit(v: ref view, x: f64, y: f64, w: f64, h: f64) bool {
    if v.mouse_x < x {
        return false
    }
    if v.mouse_x >= (x + w) {
        return false
    }
    if v.mouse_y < y {
        return false
    }
    if v.mouse_y >= (y + h) {
        return false
    }
    return true
}

fn hit(v: ref view, x: f64, y: f64, w: f64, h: f64) bool {
    if g_ui_focus != UI_FOCUS_NONE() {
        return false
    }
    return raw_hit(v, x, y, w, h)
}

fn focus_hit(v: ref view, owner: i32, x: f64, y: f64, w: f64, h: f64) bool {
    if g_ui_focus == UI_FOCUS_NONE() {
        return raw_hit(v, x, y, w, h)
    }
    if g_ui_focus == owner {
        return raw_hit(v, x, y, w, h)
    }
    return false
}

fn sync_ui_focus() {
    g_ui_focus = UI_FOCUS_NONE()
    if g_main_menu_open >= 0 {
        g_ui_focus = UI_FOCUS_MAIN_MENU()
    } else if g_pop_kind != 0 {
        g_ui_focus = UI_FOCUS_POPUP()
    } else if g_chat_menu_chat >= 0 {
        g_ui_focus = UI_FOCUS_CHAT_MENU()
    }
}

fn reset_view_input(v: ref view) {
    v.mouse_pressed = false
    v.mouse_released = false
    v.mouse_right_pressed = false
    v.mouse_right_released = false
    v.mouse_middle_pressed = false
    v.mouse_middle_released = false
    v.scroll_x = 0.0
    v.scroll_y = 0.0
    view_clear_key_presses(v)
}

fn draw_label(r: ref ui_renderer, x: f64, y: f64, text: str) {
    ui_draw_text(r, x, y, text, small_px(), col_muted(), FONT_MONO())
}

fn draw_text_clipped(r: ref ui_renderer, x: f64, y: f64, w: f64, h: f64, text: str, px: f64, color: u32) {
    if w > 0.0 {
        if h > 0.0 {
            ui_push_clip(r, x, y, w, h)
            ui_draw_text(r, x, y, text, px, color, FONT_MONO())
            ui_pop_clip(r)
        }
    }
}

// Text y that centers the visible glyphs of one `px` line in the (y, h) band.
fn text_center_y(r: ref ui_renderer, y: f64, h: f64, px: f64) f64 {
    return ui_text_v_center_y(r, y, h, px, FONT_MONO())
}

fn draw_pill(r: ref ui_renderer, x: f64, y: f64, text: str, bg: u32, fg: u32) {
    let tw = ui_text_width(r, text, small_px(), FONT_MONO())
    ui_fill_round_rect(r, x, y, tw + 16.0, 22.0, 4.0, bg, 0.0)
    ui_draw_text(r, x + 8.0, text_center_y(r, y, 22.0, small_px()), text, small_px(), fg, FONT_MONO())
}

fn draw_centered_text(r: ref ui_renderer, x: f64, y: f64, w: f64, h: f64, text: str, px: f64, color: u32) {
    if w > 0.0 {
        if h > 0.0 {
            let tw = ui_text_width(r, text, px, FONT_MONO())
            if tw <= 0.0 {
                tw = text.len as f64 * px * 0.6
            }
            let tx = x + (w - tw) * 0.5
            let ty = ui_text_v_center_y(r, y, h, px, FONT_MONO())
            ui_push_clip(r, x, y, w, h)
            ui_draw_text(r, tx, ty, text, px, color, FONT_MONO())
            ui_pop_clip(r)
        }
    }
}

// ---- shared main menu -----------------------------------------------------

fn main_menu_h() f64 { return 30.0 }
fn main_menu_count() i32 { return 5 }
fn main_menu_item_h() f64 { return 28.0 }

fn main_menu_label(i: i32) str {
    if i == 0 {
        return "File"
    }
    if i == 1 {
        return "Edit"
    }
    if i == 2 {
        return "View"
    }
    if i == 3 {
        return "Window"
    }
    return "Help"
}

fn main_menu_item_count(menu: i32) i32 {
    if menu == 0 {
        return 5
    }
    if menu == 1 {
        return 6
    }
    if menu == 2 {
        return 2
    }
    if menu == 3 {
        return 1
    }
    return 2
}

fn main_menu_item_label(menu: i32, item: i32) str {
    if menu == 0 {
        if item == 0 {
            return "New Window"
        }
        if item == 1 {
            return "Open Folder..."
        }
        if item == 2 {
            return "Settings..."
        }
        if item == 3 {
            return "Save"
        }
        return "Close Editor"
    }
    if menu == 1 {
        if item == 0 {
            return "Undo"
        }
        if item == 1 {
            return "Redo"
        }
        if item == 2 {
            return "Cut"
        }
        if item == 3 {
            return "Copy"
        }
        if item == 4 {
            return "Paste"
        }
        return "Select All"
    }
    if menu == 2 {
        if item == 0 {
            return "Code"
        }
        return "Agent"
    }
    if menu == 3 {
        return "Reset Layout"
    }
    if item == 0 {
        return "Keyboard Shortcuts"
    }
    return "About NSCode"
}

fn main_menu_item_shortcut(menu: i32, item: i32) str {
    if menu == 0 {
        if item == 3 {
            return "Ctrl/Cmd+S"
        }
        if item == 4 {
            return "Ctrl/Cmd+W"
        }
        return ""
    }
    if menu == 1 {
        if item == 0 {
            return "Ctrl/Cmd+Z"
        }
        if item == 1 {
            return "Ctrl/Cmd+Shift+Z"
        }
        if item == 2 {
            return "Ctrl/Cmd+X"
        }
        if item == 3 {
            return "Ctrl/Cmd+C"
        }
        if item == 4 {
            return "Ctrl/Cmd+V"
        }
        return "Ctrl/Cmd+A"
    }
    return ""
}

fn main_menu_separator_after(menu: i32, item: i32) bool {
    if menu == 0 {
        if item == 1 {
            return true
        }
        if item == 2 {
            return true
        }
    }
    if menu == 1 {
        if item == 1 {
            return true
        }
        if item == 4 {
            return true
        }
    }
    return false
}

fn main_menu_separator_gap() f64 { return 10.0 }

fn main_menu_item_y(menu: i32, item: i32) f64 {
    let y = main_menu_h() + 3.0
    for i in 0 to item {
        y = y + main_menu_item_h()
        if main_menu_separator_after(menu, i) {
            y = y + main_menu_separator_gap()
        }
    }
    return y
}

fn main_menu_dropdown_h(menu: i32) f64 {
    let h = 8.0
    let count = main_menu_item_count(menu)
    for i in 0 to count {
        h = h + main_menu_item_h()
        if main_menu_separator_after(menu, i) {
            h = h + main_menu_separator_gap()
        }
    }
    return h
}

fn main_menu_item_at(menu: i32, mouse_y: f64) i32 {
    let result: i32 = -1
    let count = main_menu_item_count(menu)
    for i in 0 to count {
        let iy = main_menu_item_y(menu, i)
        if result < 0 {
            if mouse_y >= iy {
                if mouse_y < (iy + main_menu_item_h()) {
                    result = i
                }
            }
        }
    }
    return result
}

fn main_menu_item_enabled(menu: i32, item: i32) bool {
    if menu == 1 {
        if g_mode != MODE_CODE() {
            return false
        }
        if item == 0 {
            return can_undo()
        }
        if item == 1 {
            return can_redo()
        }
        if item == 2 {
            return has_selection()
        }
        if item == 3 {
            return has_selection()
        }
        if item == 5 {
            return doc_len() > 0
        }
    }
    return true
}

fn main_menu_button_w(r: ref ui_renderer, i: i32) f64 {
    return ui_text_width(r, main_menu_label(i), small_px(), FONT_MONO()) + 24.0
}

fn main_menu_anchor_x(r: ref ui_renderer, index: i32) f64 {
    let x = 8.0
    for i in 0 to index {
        x = x + main_menu_button_w(r, i)
    }
    return x
}

fn main_menu_dropdown_w(menu: i32) f64 {
    if menu == 0 {
        return 190.0
    }
    if menu == 1 {
        return 180.0
    }
    if menu == 2 {
        return 168.0
    }
    if menu == 3 {
        return 180.0
    }
    return 210.0
}

fn main_menu_dropdown_x(r: ref ui_renderer, menu: i32, canvas_w: f64) f64 {
    let x = main_menu_anchor_x(r, menu)
    let pw = main_menu_dropdown_w(menu)
    if x + pw > canvas_w - 4.0 {
        x = canvas_w - pw - 4.0
    }
    if x < 4.0 {
        x = 4.0
    }
    return x
}

fn main_menu_run_action(v: ref view, menu: i32, item: i32) {
    if menu == 0 {
        if item == 0 {
            let folder = os_open_folder_dialog("Choose a folder for the new NSCode window")
            if folder != "" {
                os_launch_ns_project(folder, g_native_entry)
            }
        } else if item == 1 {
            let folder = os_open_folder_dialog("Open a project folder")
            if folder != "" {
                workspace_open_root(folder)
                chat_load_project()
                g_code_scroll = 0.0
                g_tree_scroll = 0.0
                g_dialog_scroll = 0.0
            }
        } else if item == 2 {
            if g_mode != MODE_SETTINGS() {
                g_settings_return_mode = g_mode
            }
            g_mode = MODE_SETTINGS()
        } else if item == 3 {
            workspace_save_active()
        } else if g_workspace_active >= 0 {
            workspace_close_tab(g_workspace_active)
        }
    } else if menu == 1 {
        if g_mode == MODE_CODE() {
            if item == 0 {
                undo()
            } else if item == 1 {
                redo()
            } else if item == 2 {
                if has_selection() {
                    view_set_clipboard(v, selected_text())
                    delete_selection()
                }
            } else if item == 3 {
                if has_selection() {
                    view_set_clipboard(v, selected_text())
                }
            } else if item == 4 {
                let clip = view_get_clipboard(v)
                if clip != "" {
                    paste_str(clip)
                }
            } else {
                select_all()
            }
            g_caret_follow = true
        }
    } else if menu == 2 {
        if item == 0 {
            g_mode = MODE_CODE()
        } else {
            g_mode = MODE_AGENT()
        }
    } else if menu == 3 {
        g_dialog_scroll = 0.0
        g_code_scroll = 0.0
        g_tree_scroll = 0.0
        g_dialog_follow = true
    }
}

fn main_menu_top_at(r: ref ui_renderer, v: ref view) i32 {
    let result: i32 = -1
    for i in 0 to main_menu_count() {
        if result < 0 {
            let bx = main_menu_anchor_x(r, i)
            let bw = main_menu_button_w(r, i)
            if focus_hit(v, UI_FOCUS_MAIN_MENU(), bx, 0.0, bw, main_menu_h()) {
                result = i
            }
        }
    }
    return result
}

fn main_menu_in_dropdown(r: ref ui_renderer, v: ref view, w: f64, menu: i32) bool {
    if menu < 0 {
        return false
    }
    let px = main_menu_dropdown_x(r, menu, w)
    let py = main_menu_h() - 1.0
    return focus_hit(v, UI_FOCUS_MAIN_MENU(), px, py, main_menu_dropdown_w(menu), main_menu_dropdown_h(menu))
}

// A click on any top-level option enters menu focus. While focused, hovering a
// different top-level option switches its dropdown without another click.
// Clicking a dropdown action or leaving both the top options and active
// dropdown exits focus. Focused menus consume outside clicks so they cannot
// leak through into the editor or agent content beneath them.
fn handle_main_menu_input(r: ref ui_renderer, v: ref view, w: f64) {
    let top = main_menu_top_at(r, v)

    if g_main_menu_open < 0 {
        if v.mouse_pressed {
            if top >= 0 {
                g_main_menu_open = top
                g_pop_kind = 0
                g_chat_menu_chat = -1
                g_ui_focus = UI_FOCUS_MAIN_MENU()
                g_code_drag = false
                v.mouse_pressed = false
                v.mouse_down = false
            }
        }
    } else {
        // Hover-switch first so dropdown hit-testing uses the newly active menu.
        if top >= 0 {
            g_main_menu_open = top
        }

        let menu = g_main_menu_open
        let in_dropdown = main_menu_in_dropdown(r, v, w, menu)
        if v.mouse_pressed {
            if top >= 0 {
                // A top-level click keeps the menu focused; hover already chose
                // the active dropdown above.
                g_main_menu_open = top
            } else if in_dropdown {
                let item = main_menu_item_at(menu, v.mouse_y)
                if item >= 0 {
                    if main_menu_item_enabled(menu, item) {
                        main_menu_run_action(v, menu, item)
                    }
                }
                g_main_menu_open = -1
            } else {
                g_main_menu_open = -1
            }
            g_code_drag = false
            v.mouse_pressed = false
            v.mouse_down = false
        } else if top < 0 {
            if in_dropdown == false {
                g_main_menu_open = -1
                g_code_drag = false
            }
        }
        // While focused, the menu owns the left-button level as well as its
        // edge. This prevents drag/click logic beneath the dropdown from seeing
        // the same physical press.
        v.mouse_down = false
    }
}

fn draw_main_menu(r: ref ui_renderer, v: ref view, w: f64) {
    let bar_h = main_menu_h()
    ui_fill_rect(r, 0.0, 0.0, w, bar_h, col_menu_bg(), 0.0)
    ui_fill_rect(r, 0.0, bar_h - 1.0, w, 1.0, col_status_line(), 0.0)

    for i in 0 to main_menu_count() {
        let bx = main_menu_anchor_x(r, i)
        let bw = main_menu_button_w(r, i)
        if g_main_menu_open == i {
            ui_fill_round_rect(r, bx, 3.0, bw, bar_h - 6.0, 4.0, col_menu_hover(), 0.0)
        } else if focus_hit(v, UI_FOCUS_MAIN_MENU(), bx, 0.0, bw, bar_h) {
            ui_fill_round_rect(r, bx, 3.0, bw, bar_h - 6.0, 4.0, col_surface(), 0.0)
        }
        ui_draw_text(r, bx + 12.0, text_center_y(r, 0.0, bar_h, small_px()), main_menu_label(i), small_px(), col_text(), FONT_MONO())
    }

    if g_main_menu_open >= 0 {
        let menu = g_main_menu_open
        let px = main_menu_dropdown_x(r, menu, w)
        let py = bar_h - 1.0
        let pw = main_menu_dropdown_w(menu)
        let count = main_menu_item_count(menu)
        let ph = main_menu_dropdown_h(menu)
        g_main_menu_x = px
        g_main_menu_y = main_menu_item_y(menu, 0)
        g_main_menu_w = pw

        ui_fill_round_rect(r, px, py, pw, ph, 6.0, col_surface(), 0.0)
        ui_stroke_round_rect(r, px, py, pw, ph, 6.0, 1.0, col_line(), 0.0)
        for i in 0 to count {
            let iy = main_menu_item_y(menu, i)
            let enabled = main_menu_item_enabled(menu, i)
            if enabled {
                if focus_hit(v, UI_FOCUS_MAIN_MENU(), px + 4.0, iy, pw - 8.0, main_menu_item_h()) {
                    ui_fill_round_rect(r, px + 4.0, iy, pw - 8.0, main_menu_item_h(), 4.0, col_menu_hover(), 0.0)
                }
            }
            let fg = col_text()
            if enabled == false {
                fg = col_muted()
            }
            ui_draw_text(r, px + 14.0, text_center_y(r, iy, main_menu_item_h(), small_px()), main_menu_item_label(menu, i), small_px(), fg, FONT_MONO())
            let shortcut = main_menu_item_shortcut(menu, i)
            if shortcut != "" {
                let sw = ui_text_width(r, shortcut, small_px(), FONT_MONO())
                ui_draw_text(r, px + pw - sw - 14.0, text_center_y(r, iy, main_menu_item_h(), small_px()), shortcut, small_px(), col_muted(), FONT_MONO())
            }
            if main_menu_separator_after(menu, i) {
                let sy = iy + main_menu_item_h() + main_menu_separator_gap() * 0.5
                ui_fill_rect(r, px + 10.0, sy, pw - 20.0, 1.0, col_line(), 0.0)
            }
        }
    }
}

fn mode_switch_x(w: f64) f64 {
    return 14.0
}

fn mode_switch_y(h: f64) f64 {
    return h - 68.0
}

fn handle_mode_switch_input(v: ref view, w: f64, h: f64) {
    if g_mode != MODE_SETTINGS() {
        let switch_w = 150.0
        let switch_h = 28.0
        let switch_x = mode_switch_x(w)
        let switch_y = mode_switch_y(h)
        let gap = 4.0
        let button_w = (switch_w - gap) * 0.5
        let code_x = switch_x
        let agent_x = switch_x + button_w + gap
        if v.mouse_pressed {
            let switched = false
            if hit(v, code_x, switch_y, button_w, switch_h) {
                g_mode = MODE_CODE()
                switched = true
            } else if hit(v, agent_x, switch_y, button_w, switch_h) {
                g_mode = MODE_AGENT()
                switched = true
            }
            if switched {
                v.mouse_pressed = false
                v.mouse_down = false
            }
        }
    }
}

fn update_fps() {
    let now = os_time()
    if g_last_frame_time > 0.0 {
        let dt = now - g_last_frame_time
        if dt > 0.0 {
            g_fps = 1.0 / dt
            g_fps_i = g_fps as i32
        }
    }
    g_last_frame_time = now
}

fn fps_text() str {
    return "FPS " + itos(g_fps_i)
}

fn chat_cap() i32 { return 16 }

fn chat_msg_index(chat: i32, message: i32) i32 {
    return chat * msg_cap() + message
}

fn chat_title(i: i32) str {
    return g_chat_title[i]
}

fn chat_is_pinned(i: i32) bool {
    if (g_chat_pinned[i] as i32) == 1 {
        return true
    }
    return false
}

fn chat_add(title: str) {
    if g_chat_count < chat_cap() {
        g_chat_title[g_chat_count] = title
        g_chat_pinned[g_chat_count] = 0
        g_chat_msg_count[g_chat_count] = 0
        g_chat_count = g_chat_count + 1
    }
}

fn chat_copy_messages(src: i32, dst: i32) {
    g_chat_msg_count[dst] = g_chat_msg_count[src]
    for i in 0 to msg_cap() {
        let src_index = chat_msg_index(src, i)
        let dst_index = chat_msg_index(dst, i)
        g_chat_msg_text[dst_index] = g_chat_msg_text[src_index]
        g_chat_msg_role[dst_index] = g_chat_msg_role[src_index]
    }
}

fn chat_swap(a: i32, b: i32) {
    let title = g_chat_title[a]
    let pinned = g_chat_pinned[a] as i32
    let count = g_chat_msg_count[a]
    let temp_text = [i32: str](64)
    let temp_role = [i32](64)
    for i in 0 to msg_cap() {
        let ai = chat_msg_index(a, i)
        temp_text[i] = g_chat_msg_text[ai]
        temp_role[i] = g_chat_msg_role[ai]
    }
    g_chat_title[a] = g_chat_title[b]
    g_chat_pinned[a] = g_chat_pinned[b]
    chat_copy_messages(b, a)
    g_chat_title[b] = title
    g_chat_pinned[b] = pinned
    g_chat_msg_count[b] = count
    for i in 0 to msg_cap() {
        let bi = chat_msg_index(b, i)
        g_chat_msg_text[bi] = temp_text[i]
        g_chat_msg_role[bi] = temp_role[i]
    }
    if g_selected_chat == a {
        g_selected_chat = b
    } else if g_selected_chat == b {
        g_selected_chat = a
    }
}

// Move a chat through adjacent swaps so its entire transcript travels with it.
fn chat_move(src: i32, dst: i32) {
    if src < dst {
        for i in src to dst {
            chat_swap(i, i + 1)
        }
    } else if src > dst {
        for k in dst to src {
            let i = src - (k - dst)
            chat_swap(i, i - 1)
        }
    }
}

fn chat_store_path() str {
    return g_workspace_root + "/.ns/chat/conversations.db"
}

fn chat_field(value: str) str {
    return itos(value.len) + ":" + value
}

fn chat_parse_i32(value: str) i32 {
    let n: i32 = 0
    for i in 0 to value.len {
        let digit = byte_at(value, i) - 48
        if digit >= 0 {
            if digit <= 9 {
                n = n * 10 + digit
            }
        }
    }
    return n
}

fn chat_take_field(data: str) str {
    if g_chat_store_ok == false {
        return ""
    }
    let size: i32 = 0
    let digits: i32 = 0
    loop g_chat_store_cursor < data.len {
        let b = byte_at(data, g_chat_store_cursor)
        if b == 58 {
            g_chat_store_cursor = g_chat_store_cursor + 1
            break
        }
        if b < 48 {
            g_chat_store_ok = false
            return ""
        }
        if b > 57 {
            g_chat_store_ok = false
            return ""
        }
        size = size * 10 + b - 48
        digits = digits + 1
        g_chat_store_cursor = g_chat_store_cursor + 1
    }
    if digits == 0 {
        g_chat_store_ok = false
        return ""
    }
    if g_chat_store_cursor + size > data.len {
        g_chat_store_ok = false
        return ""
    }
    let value = substr(data, g_chat_store_cursor, size)
    g_chat_store_cursor = g_chat_store_cursor + size
    return value
}

fn chat_store_current() {
    if g_selected_chat >= 0 {
        if g_selected_chat < g_chat_count {
            g_chat_msg_count[g_selected_chat] = g_msg_count
            for i in 0 to msg_cap() {
                let dst = chat_msg_index(g_selected_chat, i)
                g_chat_msg_text[dst] = g_msg_text[i]
                g_chat_msg_role[dst] = g_msg_role[i]
            }
        }
    }
}

fn chat_load_selected() {
    g_msg_count = 0
    for i in 0 to msg_cap() {
        g_msg_text[i] = ""
        g_msg_role[i] = 0
    }
    if g_selected_chat >= 0 {
        if g_selected_chat < g_chat_count {
            g_msg_count = g_chat_msg_count[g_selected_chat]
            for i in 0 to g_msg_count {
                let src = chat_msg_index(g_selected_chat, i)
                g_msg_text[i] = g_chat_msg_text[src]
                g_msg_role[i] = g_chat_msg_role[src]
            }
        }
    }
    g_dialog_scroll = 0.0
    g_dialog_follow = true
}

fn chat_select(index: i32) {
    if index >= 0 {
        if index < g_chat_count {
            chat_store_current()
            g_selected_chat = index
            chat_load_selected()
            chat_save_project()
        }
    }
}

fn chat_save_project() bool {
    chat_store_current()
    if g_chat_persist == false {
        return true
    }
    let dir = g_workspace_root + "/.ns/chat"
    if os_make_dirs(dir) == 0 {
        return false
    }
    let data = chat_field("NSCHAT1")
    data = data + chat_field(itos(g_chat_count))
    data = data + chat_field(itos(g_chat_archived))
    data = data + chat_field(itos(g_selected_chat))
    for chat in 0 to g_chat_count {
        data = data + chat_field(g_chat_title[chat])
        data = data + chat_field(itos(g_chat_pinned[chat] as i32))
        let count = g_chat_msg_count[chat]
        data = data + chat_field(itos(count))
        for message in 0 to count {
            let index = chat_msg_index(chat, message)
            data = data + chat_field(itos(g_chat_msg_role[index] as i32))
            data = data + chat_field(g_chat_msg_text[index])
        }
    }
    let fd = open(chat_store_path(), "wb")
    if fd == 0 {
        return false
    }
    write(fd, data)
    close(fd)
    return true
}

fn chat_clear_project() {
    g_chat_count = 0
    g_chat_archived = 0
    g_selected_chat = -1
    g_msg_count = 0
    for chat in 0 to chat_cap() {
        g_chat_title[chat] = ""
        g_chat_pinned[chat] = 0
        g_chat_msg_count[chat] = 0
        for message in 0 to msg_cap() {
            let index = chat_msg_index(chat, message)
            g_chat_msg_text[index] = ""
            g_chat_msg_role[index] = 0
        }
    }
    for i in 0 to msg_cap() {
        g_msg_text[i] = ""
        g_msg_role[i] = 0
    }
}

fn chat_load_project() bool {
    chat_clear_project()
    g_chat_store_loaded = true
    let fd = open(chat_store_path(), "rb")
    if fd == 0 {
        return false
    }
    let data = read(fd)
    close(fd)
    g_chat_store_cursor = 0
    g_chat_store_ok = true
    if chat_take_field(data) != "NSCHAT1" {
        return false
    }
    let count = chat_parse_i32(chat_take_field(data))
    if count > chat_cap() {
        g_chat_store_ok = false
        return false
    }
    g_chat_count = count
    g_chat_archived = chat_parse_i32(chat_take_field(data))
    g_selected_chat = chat_parse_i32(chat_take_field(data))
    for chat in 0 to g_chat_count {
        g_chat_title[chat] = chat_take_field(data)
        g_chat_pinned[chat] = chat_parse_i32(chat_take_field(data))
        let message_count = chat_parse_i32(chat_take_field(data))
        if message_count > msg_cap() {
            g_chat_store_ok = false
            return false
        }
        g_chat_msg_count[chat] = message_count
        for message in 0 to message_count {
            let index = chat_msg_index(chat, message)
            g_chat_msg_role[index] = chat_parse_i32(chat_take_field(data))
            g_chat_msg_text[index] = chat_take_field(data)
        }
    }
    if g_chat_store_ok == false {
        chat_clear_project()
        return false
    }
    if g_chat_count == 0 {
        g_selected_chat = -1
    } else {
        g_selected_chat = clamp_i(g_selected_chat, 0, g_chat_count - 1)
    }
    chat_load_selected()
    return true
}

fn chat_pinned_count() i32 {
    let n = 0
    for i in 0 to g_chat_count {
        if chat_is_pinned(i) {
            n = n + 1
        }
    }
    return n
}

// Pin moves the chat to the top of the list; unpin drops it to the first
// slot below the remaining pinned block.
fn chat_toggle_pin(idx: i32) {
    if chat_is_pinned(idx) {
        g_chat_pinned[idx] = 0
        chat_move(idx, chat_pinned_count())
    } else {
        g_chat_pinned[idx] = 1
        chat_move(idx, 0)
    }
}

fn chat_remove(idx: i32) {
    for i in idx to g_chat_count - 1 {
        g_chat_title[i] = g_chat_title[i + 1]
        g_chat_pinned[i] = g_chat_pinned[i + 1]
        chat_copy_messages(i + 1, i)
    }
    g_chat_count = g_chat_count - 1
    if g_selected_chat > idx {
        g_selected_chat = g_selected_chat - 1
    }
    if g_selected_chat >= g_chat_count {
        g_selected_chat = g_chat_count - 1
    }
    if g_selected_chat < 0 {
        if g_chat_count > 0 {
            g_selected_chat = 0
        }
    }
    chat_load_selected()
}

fn draw_mode_switch(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    let pad = 3.0
    let half_w = (w - pad * 2.0) * 0.5
    let code_x = x + pad
    let agent_x = x + pad + half_w

    ui_fill_round_rect(r, x, y, w, h, 7.0, col_surface_hi(), 0.0)
    ui_stroke_round_rect(r, x, y, w, h, 7.0, 1.0, col_line(), 0.0)
    let active_x = agent_x
    if g_mode == MODE_CODE() {
        active_x = code_x
    }
    ui_fill_round_rect(r, active_x, y + pad, half_w, h - pad * 2.0, 4.0, col_accent(), 0.0)

    let code_color = col_text()
    let agent_color = col_bg()
    if g_mode == MODE_CODE() {
        code_color = col_bg()
        agent_color = col_text()
    }
    draw_centered_text(r, code_x, y + pad, half_w, h - pad * 2.0, "Code", small_px(), code_color)
    draw_centered_text(r, agent_x, y + pad, half_w, h - pad * 2.0, "Agent", small_px(), agent_color)

}

fn draw_fps(r: ref ui_renderer, x: f64, y: f64, w: f64) {
    let badge_w = 132.0
    let badge_h = 28.0
    let badge_x = x + w - badge_w - 10.0
    let badge_y = y + 5.0
    let text = fps_text()
    if badge_x > x {
        ui_fill_rect(r, badge_x, badge_y, badge_w, badge_h, col_accent(), 0.0)
        ui_fill_rect(r, badge_x + 2.0, badge_y + 2.0, badge_w - 4.0, badge_h - 4.0, col_bg(), 0.0)
        let ty = text_center_y(r, badge_y, badge_h, small_px())
        draw_text_clipped(r, badge_x + 10.0, ty, badge_w - 20.0, 16.0, text, small_px(), col_accent())
    }
}

fn chat_row_h() f64 { return 24.0 }
fn chat_row_stride() f64 { return 28.0 }
fn chat_rows_top() f64 { return 14.0 }
fn chat_btn_d() f64 { return 18.0 }
fn chat_menu_items() i32 { return 3 }

// Text colour with an explicit alpha (col_text is #d7dde5).
fn col_text_fade(a: f64) u32 {
    return ui_pack_rgba_floats(0.843, 0.867, 0.898, a)
}

// Alpha ramp for the trailing glyphs of a truncated row title.
fn fade_alpha(i: i32) f64 {
    if i == 0 {
        return 0.72
    }
    if i == 1 {
        return 0.52
    }
    if i == 2 {
        return 0.32
    }
    return 0.14
}

// One line of mono text that never leaves [x, x+w]: text that fits is drawn
// as-is, longer text is cut at the container edge and its last glyphs fade
// out to transparent instead of ending in a hard clip.
fn draw_faded_text(r: ref ui_renderer, x: f64, y: f64, w: f64, text: str, px: f64) {
    let char_w = ui_mono_char_width(r, px, FONT_MONO())
    if char_w <= 0.0 {
        char_w = px * 0.6
    }
    let fit = (w / char_w) as i32
    if fit > 0 {
        let n = text.len
        if n <= fit {
            ui_draw_text(r, x, y, text, px, col_text(), FONT_MONO())
        } else {
            let fade = 4
            if fade > fit {
                fade = fit
            }
            let solid = fit - fade
            let head = substr(text, 0, solid)
            ui_draw_text(r, x, y, head, px, col_text(), FONT_MONO())
            let gx = x + ui_text_width(r, head, px, FONT_MONO())
            for i in 0 to fade {
                ui_draw_text(r, gx, y, substr(text, solid + i, 1), px, col_text_fade(fade_alpha(i)), FONT_MONO())
                gx = gx + char_w
            }
        }
    }
}

// One single-line history row: the title truncates with a glyph fade at the
// container edge, and hovering the row reveals a "..." menu button at its end
// (pin / archive / delete). Pinned rows carry a small accent dot.
fn draw_chat_row(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, idx: i32) {
    let rx = x + 10.0
    let rw = w - 20.0
    let hot = hit(v, rx, y, rw, chat_row_h())
    let show_btn = hot
    if g_chat_menu_chat == idx {
        show_btn = true
    }

    let bx = rx + rw - chat_btn_d() - 4.0
    let by = y + (chat_row_h() - chat_btn_d()) * 0.5

    if v.mouse_pressed {
        if g_click_used == false {
            if show_btn {
                if hit(v, bx, by, chat_btn_d(), chat_btn_d()) {
                    g_chat_menu_chat = idx
                    g_chat_menu_btn_x = bx
                    g_chat_menu_btn_y = by
                    g_ui_focus = UI_FOCUS_CHAT_MENU()
                    g_click_used = true
                    v.mouse_pressed = false
                    v.mouse_down = false
                }
            }
            if g_click_used == false {
                if hot {
                    chat_select(idx)
                }
            }
        }
    }

    if idx == g_selected_chat {
        ui_fill_round_rect(r, rx, y, rw, chat_row_h(), 4.0, col_surface_hi(), 0.0)
    } else if hot {
        ui_fill_round_rect(r, rx, y, rw, chat_row_h(), 4.0, col_surface(), 0.0)
    }

    let tx = x + 24.0
    let text_end = rx + rw - 10.0
    if show_btn {
        text_end = bx - 6.0
    }
    draw_faded_text(r, tx, text_center_y(r, y, chat_row_h(), font_px()), text_end - tx, chat_title(idx), font_px())
    if chat_is_pinned(idx) {
        ui_fill_circle(r, rx + 6.0, y + chat_row_h() * 0.5, 2.5, col_accent(), 0.5)
    }

    if show_btn {
        let bbg = col_surface_hi()
        if hit(v, bx, by, chat_btn_d(), chat_btn_d()) {
            bbg = col_line()
        }
        ui_fill_round_rect(r, bx, by, chat_btn_d(), chat_btn_d(), 4.0, bbg, 0.0)
        let dcy = by + chat_btn_d() * 0.5
        ui_fill_circle(r, bx + 5.0, dcy, 1.25, col_text(), 0.5)
        ui_fill_circle(r, bx + 9.0, dcy, 1.25, col_text(), 0.5)
        ui_fill_circle(r, bx + 13.0, dcy, 1.25, col_text(), 0.5)
    }
}

fn chat_menu_label(i: i32) str {
    if i == 0 {
        if g_chat_menu_chat >= 0 {
            if chat_is_pinned(g_chat_menu_chat) {
                return "Unpin"
            }
        }
        return "Pin"
    }
    if i == 1 {
        return "Archive"
    }
    return "Delete"
}

fn chat_menu_action(chat: i32, item: i32) {
    if item == 0 {
        chat_toggle_pin(chat)
    } else if item == 1 {
        g_chat_archived = g_chat_archived + 1
        chat_remove(chat)
    } else {
        chat_remove(chat)
    }
    chat_save_project()
}

// Resolve last frame's chat row menu against this frame's click: an item click
// runs the action, a click on the anchor button just closes the menu, and any
// other click dismisses it (without eating the click).
fn handle_chat_menu_input(v: ref view) {
    if g_chat_menu_chat >= 0 {
        if v.mouse_pressed {
            let mh = 3.0 * pop_item_h()
            if focus_hit(v, UI_FOCUS_CHAT_MENU(), g_chat_menu_x, g_chat_menu_y, g_chat_menu_w, mh) {
                let idx = ((v.mouse_y - g_chat_menu_y) / pop_item_h()) as i32
                idx = clamp_i(idx, 0, chat_menu_items() - 1)
                chat_menu_action(g_chat_menu_chat, idx)
                g_click_used = true
            } else if focus_hit(v, UI_FOCUS_CHAT_MENU(), g_chat_menu_btn_x, g_chat_menu_btn_y, chat_btn_d(), chat_btn_d()) {
                g_click_used = true
            }
            g_chat_menu_chat = -1
            v.mouse_pressed = false
            v.mouse_down = false
        }
    }
}

// The pin/archive/delete menu anchored to a row's "..." button, right-aligned
// inside the history rail. Drawn after the rows so it floats above them.
fn draw_chat_menu(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    let mw = 112.0
    let mh = 3.0 * pop_item_h() + 12.0
    let px = x + w - mw - 12.0
    let py = g_chat_menu_btn_y + chat_btn_d() + 4.0
    if (py + mh) > (y + h - 8.0) {
        py = g_chat_menu_btn_y - mh - 4.0
    }
    g_chat_menu_x = px
    g_chat_menu_y = py + 6.0
    g_chat_menu_w = mw
    ui_fill_round_rect(r, px, py, mw, mh, 8.0, col_surface(), 0.0)
    ui_stroke_round_rect(r, px, py, mw, mh, 8.0, 1.0, col_line(), 0.0)
    for i in 0 to chat_menu_items() {
        let iy = py + 6.0 + (i as f64) * pop_item_h()
        if focus_hit(v, UI_FOCUS_CHAT_MENU(), px, iy, mw, pop_item_h()) {
            ui_fill_rect(r, px + 4.0, iy, mw - 8.0, pop_item_h(), col_surface_hi(), 0.0)
        }
        let fg = col_text()
        if i == 2 {
            fg = col_red()
        }
        ui_draw_text(r, px + 14.0, text_center_y(r, iy, pop_item_h(), small_px()), chat_menu_label(i), small_px(), fg, FONT_MONO())
    }
}

fn draw_history(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    ui_fill_rect(r, x, y, w, h, col_agent_history(), 0.0)
    ui_push_clip(r, x, y, w, h)
    let row_y = y + chat_rows_top()
    for i in 0 to g_chat_count {
        draw_chat_row(r, v, x, row_y, w, i)
        row_y = row_y + chat_row_stride()
    }
    if g_chat_archived > 0 {
        draw_label(r, x + 18.0, row_y + 8.0, "ARCHIVED " + itos(g_chat_archived))
    }
    let foot_y = y + h - 124.0
    if foot_y > (row_y + 60.0) {
        ui_fill_round_rect(r, x + 14.0, foot_y, w - 28.0, 62.0, 4.0, col_surface(), 0.0)
        draw_label(r, x + 28.0, foot_y + 13.0, "WORKSPACE")
        draw_text_clipped(r, x + 28.0, foot_y + 34.0, w - 56.0, 16.0, g_workspace_root, small_px(), col_accent())
    }
    ui_pop_clip(r)
    if g_chat_menu_chat >= 0 {
        draw_chat_menu(r, v, x, y, w, h)
    }
}

// ---- agent session model ----------------------------------------------------

fn ROLE_USER() i32 { return 0 }
fn ROLE_AGENT() i32 { return 1 }
fn ROLE_EVENT() i32 { return 2 }

fn msg_cap() i32 { return 64 }
fn attach_cap() i32 { return 4 }
fn input_line_h() f64 { return code_line_h() }
fn ctl_h() f64 { return 26.0 }
fn send_d() f64 { return 30.0 }
fn pop_item_h() f64 { return 26.0 }

fn perm_count() i32 { return 3 }

fn perm_label(i: i32) str {
    if i == 0 {
        return "Read Only"
    }
    if i == 2 {
        return "Full Access"
    }
    return "Auto"
}

fn module_count() i32 { return 4 }

fn module_label(i: i32) str {
    if i == 1 {
        return "nscode/cli"
    }
    if i == 2 {
        return "nscode/web"
    }
    if i == 3 {
        return "lib/ui"
    }
    return "nscode/native"
}

fn attach_pool(i: i32) str {
    if i == 1 {
        return "render.ns"
    }
    if i == 2 {
        return "editor.ns"
    }
    if i == 3 {
        return "icon.png"
    }
    return "main.ns"
}

fn push_msg(role: i32, text: str) {
    if g_msg_count < msg_cap() {
        g_msg_text[g_msg_count] = text
        g_msg_role[g_msg_count] = role
        g_msg_count = g_msg_count + 1
        g_dialog_follow = true
    }
}

fn chat_title_from_message(text: str) str {
    let n = text.len
    if n > 48 {
        n = 48
    }
    for i in 0 to n {
        if i < n {
            if byte_at(text, i) == 10 {
                n = i
            }
        }
    }
    let title = substr(text, 0, n)
    if title == "" {
        return "New conversation"
    }
    return title
}

fn add_attachment() {
    if g_attach_count < attach_cap() {
        g_attach_name[g_attach_count] = attach_pool(g_attach_seq % 4)
        g_attach_count = g_attach_count + 1
        g_attach_seq = g_attach_seq + 1
    }
}

fn remove_attachment(idx: i32) {
    for j in idx to g_attach_count - 1 {
        g_attach_name[j] = g_attach_name[j + 1]
    }
    if g_attach_count > 0 {
        g_attach_count = g_attach_count - 1
    }
}

// Post real composer content into the selected project's persistent transcript.
// No synthetic agent reply is generated; an agent/backend can append messages
// to the same project store and they will be shown on the next project load.
fn composer_send() {
    let has_content = false
    if g_input_text != "" {
        has_content = true
    }
    if g_attach_count > 0 {
        has_content = true
    }
    if has_content {
        let text = g_input_text
        if g_attach_count > 0 {
            let names = ""
            for i in 0 to g_attach_count {
                if i > 0 {
                    names = names + ", "
                }
                names = names + g_attach_name[i]
            }
            if text != "" {
                text = text + nl()
            }
            text = text + "[attachments: " + names + "]"
        }
        if g_selected_chat < 0 {
            chat_add(chat_title_from_message(text))
            g_selected_chat = g_chat_count - 1
            chat_load_selected()
        }
        push_msg(ROLE_USER(), text)
        g_input_text = ""
        g_attach_count = 0
        g_running = false
        chat_save_project()
    }
}

fn session_terminate() {
    if g_running {
        g_running = false
        chat_save_project()
    }
}

// ---- composer input ----------------------------------------------------------

// Polled keyboard input for the composer: printable keys append, backspace
// deletes, enter sends (shift+enter inserts a newline), cmd/ctrl+V pastes and
// escape interrupts the running session.
fn process_composer_keys(v: ref view) {
    if key_edge(v, 256) {
        session_terminate()
    }
    if g_input_focus {
        if key_edge(v, 257) {
            if key_event_shift() {
                g_input_text = g_input_text + nl()
            } else if key_event_cmd() == false {
                composer_send()
            }
        }
        if key_edge(v, 259) {
            let n = g_input_text.len
            if n > 0 {
                g_input_text = substr(g_input_text, 0, n - 1)
            }
        }
        // Printable keys: space, punctuation, digits and letters (32..96).
        // Modifiers come from the latched key event, so a quick Cmd+V cannot
        // turn into a plain "v" if Command is released before the next frame.
        for k in 32 to 97 {
            if key_edge(v, k) {
                if key_event_cmd() {
                    if k == 86 {
                        let clip = view_get_clipboard(v)
                        if clip != "" {
                            g_input_text = g_input_text + clip
                        }
                    }
                } else {
                    let c = key_char(k, key_event_shift())
                    if c != "" {
                        g_input_text = g_input_text + c
                    }
                }
            }
        }
    }
}

// ---- mono text wrapping -------------------------------------------------------

fn byte_at(s: str, i: i32) i32 {
    return (s[i] as i32) & 255
}

// Number of visual lines `text` occupies when wrapped at `cols` characters.
// Measurement helpers accumulate and return f64: casting a computed i32 to
// f64 mis-evaluates in the current interpreter (garbage upper bits), while
// f64 function returns are reliable.
fn wrap_lines_f(text: str, cols: i32) f64 {
    let lines: f64 = 1.0
    let run = 0
    let n = text.len
    for i in 0 to n {
        if byte_at(text, i) == 10 {
            lines = lines + 1.0
            run = 0
        } else {
            run = run + 1
            if run > cols {
                lines = lines + 1.0
                run = 1
            }
        }
    }
    return lines
}

// Character count of the final visual line (caret column for the composer).
fn wrap_caret_f(text: str, cols: i32) f64 {
    let run = 0
    let run_f: f64 = 0.0
    let n = text.len
    for i in 0 to n {
        if byte_at(text, i) == 10 {
            run = 0
            run_f = 0.0
        } else {
            run = run + 1
            run_f = run_f + 1.0
            if run > cols {
                run = 1
                run_f = 1.0
            }
        }
    }
    return run_f
}

// Popup row count for float layout math, same f64-return rule as above.
fn pop_count_f() f64 {
    if g_pop_kind == 1 {
        return 3.0
    }
    return 4.0
}

// Draw `text` wrapped at `cols` characters; returns the consumed height.
fn draw_wrapped(r: ref ui_renderer, x: f64, y: f64, text: str, cols: i32, px: f64, color: u32, line_h: f64) f64 {
    let start = 0
    let run = 0
    let yy = y
    let n = text.len
    for i in 0 to n {
        if byte_at(text, i) == 10 {
            ui_draw_text(r, x, yy, substr(text, start, i - start), px, color, FONT_MONO())
            yy = yy + line_h
            start = i + 1
            run = 0
        } else {
            run = run + 1
            if run > cols {
                ui_draw_text(r, x, yy, substr(text, start, i - start), px, color, FONT_MONO())
                yy = yy + line_h
                start = i
                run = 1
            }
        }
    }
    ui_draw_text(r, x, yy, substr(text, start, n - start), px, color, FONT_MONO())
    return yy + line_h - y
}

// ---- selector popup ------------------------------------------------------------

fn pop_count() i32 {
    if g_pop_kind == 1 {
        return perm_count()
    }
    return module_count()
}

fn pop_label(i: i32) str {
    if g_pop_kind == 1 {
        return perm_label(i)
    }
    return module_label(i)
}

// Resolve last frame's popup against this frame's click before anything else
// draws: a click on an item selects it, any other click closes the popup, and
// clicks on the selector buttons are consumed so they toggle instead of reopen.
fn handle_popup_input(v: ref view) {
    g_click_used = false
    if g_pop_kind != 0 {
        if v.mouse_pressed {
            let count = pop_count() & 15
            let ph = pop_count_f() * pop_item_h()
            if focus_hit(v, UI_FOCUS_POPUP(), g_pop_x, g_pop_y, g_pop_w, ph) {
                let idx = ((v.mouse_y - g_pop_y) / pop_item_h()) as i32
                idx = clamp_i(idx, 0, count - 1)
                if g_pop_kind == 1 {
                    g_perm = idx
                } else {
                    g_module = idx
                }
                g_click_used = true
            } else if focus_hit(v, UI_FOCUS_POPUP(), g_perm_btn_x, g_perm_btn_y, g_perm_btn_w, ctl_h()) {
                g_click_used = true
            } else if focus_hit(v, UI_FOCUS_POPUP(), g_module_btn_x, g_module_btn_y, g_module_btn_w, ctl_h()) {
                g_click_used = true
            }
            g_pop_kind = 0
            v.mouse_pressed = false
            v.mouse_down = false
        }
    }
}

fn draw_popup(r: ref ui_renderer, v: ref view) {
    let count = pop_count() & 15
    let count_f = pop_count_f()
    let wmax: f64 = 0.0
    for i in 0 to count {
        let tw = ui_text_width(r, pop_label(i), small_px(), FONT_MONO())
        if tw > wmax {
            wmax = tw
        }
    }
    let pw = wmax + 44.0
    let ph = count_f * pop_item_h() + 12.0
    let px = g_perm_btn_x
    if g_pop_kind == 2 {
        px = g_module_btn_x
    }
    let py = g_perm_btn_y - ph - 8.0
    g_pop_x = px
    g_pop_y = py + 6.0
    g_pop_w = pw
    ui_fill_round_rect(r, px, py, pw, ph, 8.0, col_rail(), 0.0)
    ui_stroke_round_rect(r, px, py, pw, ph, 8.0, 1.0, col_line(), 0.0)
    for i in 0 to count {
        let iy = py + 6.0 + (i as f64) * pop_item_h()
        let selected = false
        if g_pop_kind == 1 {
            if i == g_perm {
                selected = true
            }
        } else {
            if i == g_module {
                selected = true
            }
        }
        if focus_hit(v, UI_FOCUS_POPUP(), px, iy, pw, pop_item_h()) {
            ui_fill_rect(r, px + 4.0, iy, pw - 8.0, pop_item_h(), col_surface_hi(), 0.0)
        }
        let fg = col_text()
        if selected {
            fg = col_accent()
            ui_fill_circle(r, px + 12.0, iy + pop_item_h() * 0.5, 3.0, col_accent(), 0.5)
        }
        ui_draw_text(r, px + 24.0, text_center_y(r, iy, pop_item_h(), small_px()), pop_label(i), small_px(), fg, FONT_MONO())
    }
}

// ---- composer -------------------------------------------------------------------

fn draw_chevron_down(r: ref ui_renderer, cx: f64, cy: f64, color: u32) {
    let thickness = 1.8
    let radius = thickness * 0.5
    ui_stroke_line(r, cx - 3.0, cy - 1.6, cx, cy + 1.6, thickness, color, 0.5)
    ui_stroke_line(r, cx, cy + 1.6, cx + 3.0, cy - 1.6, thickness, color, 0.5)
    ui_fill_circle(r, cx - 3.0, cy - 1.6, radius, color, 0.5)
    ui_fill_circle(r, cx, cy + 1.6, radius, color, 0.5)
    ui_fill_circle(r, cx + 3.0, cy - 1.6, radius, color, 0.5)
}

// One selector pill (label + rounded down chevron). Stores its rect for hit tests and
// the popup anchor, opens the popup on click, returns the next control x.
fn draw_selector(r: ref ui_renderer, v: ref view, x: f64, y: f64, text: str, kind: i32) f64 {
    let tw = ui_text_width(r, text, small_px(), FONT_MONO())
    if tw <= 0.0 {
        tw = (text.len as f64) * small_px() * 0.6
    }
    let bw = tw + 34.0
    ui_fill_round_rect(r, x, y, bw, ctl_h(), 13.0, col_surface_hi(), 0.0)
    ui_draw_text(r, x + 12.0, text_center_y(r, y, ctl_h(), small_px()), text, small_px(), col_text(), FONT_MONO())
    draw_chevron_down(r, x + bw - 12.0, y + ctl_h() * 0.5, col_muted())
    if kind == 1 {
        g_perm_btn_x = x
        g_perm_btn_y = y
        g_perm_btn_w = bw
    } else {
        g_module_btn_x = x
        g_module_btn_y = y
        g_module_btn_w = bw
    }
    if v.mouse_pressed {
        if g_click_used == false {
            if hit(v, x, y, bw, ctl_h()) {
                g_pop_kind = kind
                g_ui_focus = UI_FOCUS_POPUP()
                g_click_used = true
                v.mouse_pressed = false
                v.mouse_down = false
            }
        }
    }
    return x + bw + 10.0
}

// Match the rounded line-and-dot arrow language used by the Code file tree,
// rotated upward for the send action.
fn draw_send_arrow(r: ref ui_renderer, cx: f64, cy: f64, color: u32) {
    let thickness = 1.8
    let radius = thickness * 0.5
    let tip_y = cy - 6.0
    let wing_y = cy - 1.0
    let tail_y = cy + 6.0
    ui_stroke_line(r, cx, tail_y, cx, tip_y, thickness, color, 0.5)
    ui_stroke_line(r, cx - 5.0, wing_y, cx, tip_y, thickness, color, 0.5)
    ui_stroke_line(r, cx + 5.0, wing_y, cx, tip_y, thickness, color, 0.5)
    ui_fill_circle(r, cx, tip_y, radius, color, 0.5)
    ui_fill_circle(r, cx - 5.0, wing_y, radius, color, 0.5)
    ui_fill_circle(r, cx + 5.0, wing_y, radius, color, 0.5)
    ui_fill_circle(r, cx, tail_y, radius, color, 0.5)
}

// The codex-style composer: rounded container with attachment chips, the
// wrapped multi-line input (grows up to 6 lines), and a control row with the
// attach button, permission/module selectors and the send/stop button.
fn draw_composer(r: ref ui_renderer, v: ref view, char_w: f64, cols: i32, shown_f: f64, total_f: f64, chips_h: f64) {
    let x = g_cmp_x
    let y = g_cmp_y
    let w = g_cmp_w
    let h = g_cmp_h
    let pad = 14.0

    if v.mouse_pressed {
        if g_click_used == false {
            if hit(v, x, y, w, h) {
                g_input_focus = true
            }
        }
    }

    ui_fill_round_rect(r, x, y, w, h, 10.0, col_agent_composer(), 0.0)

    // attachment chips
    if g_attach_count > 0 {
        let cy = y + 10.0
        let cx = x + pad
        for i in 0 to g_attach_count {
            let name = g_attach_name[i]
            let tw = ui_text_width(r, name, small_px(), FONT_MONO())
            if tw <= 0.0 {
                tw = (name.len as f64) * small_px() * 0.6
            }
            let chip_w = tw + 34.0
            ui_fill_round_rect(r, cx, cy, chip_w, 24.0, 12.0, col_surface_hi(), 0.0)
            ui_draw_text(r, cx + 10.0, text_center_y(r, cy, 24.0, small_px()), name, small_px(), col_text(), FONT_MONO())
            let rx = cx + chip_w - 18.0
            ui_stroke_line(r, rx, cy + 8.0, rx + 8.0, cy + 16.0, 1.0, col_muted(), 0.0)
            ui_stroke_line(r, rx, cy + 16.0, rx + 8.0, cy + 8.0, 1.0, col_muted(), 0.0)
            if v.mouse_pressed {
                if g_click_used == false {
                    if hit(v, rx - 4.0, cy + 4.0, 16.0, 16.0) {
                        remove_attachment(i)
                        g_click_used = true
                    }
                }
            }
            cx = cx + chip_w + 8.0
        }
    }

    // multi-line input (the last `shown_f` visual lines stay visible)
    let input_x = x + pad
    let input_y = y + 10.0 + chips_h
    let input_h = shown_f * input_line_h()
    ui_push_clip(r, input_x, input_y, w - pad * 2.0, input_h)
    let input_ty = text_center_y(r, input_y, input_line_h(), font_px())
    if g_input_text == "" {
        ui_draw_text(r, input_x, input_ty, "Describe a task for the agent", font_px(), col_muted(), FONT_MONO())
    } else {
        let skip_h = (total_f - shown_f) * input_line_h()
        draw_wrapped(r, input_x, input_ty - skip_h, g_input_text, cols, font_px(), col_text(), input_line_h())
    }
    if g_input_focus {
        let blink = ((os_time() * 2.0) as i32) % 2
        if blink == 0 {
            let caret_x = input_x + wrap_caret_f(g_input_text, cols) * char_w
            let caret_y = input_y + (shown_f - 1.0) * input_line_h()
            ui_fill_rect(r, caret_x + 1.0, caret_y, 2.0, input_line_h() - 2.0, col_editor_cursor(), 0.0)
        }
    }
    ui_pop_clip(r)

    // control row: attach, permission level, module, send/stop
    let ctl_y = y + h - 33.0
    let bx = x + pad - 2.0
    g_attach_btn_x = bx
    g_attach_btn_y = ctl_y
    ui_fill_round_rect(r, bx, ctl_y, ctl_h(), ctl_h(), 13.0, col_surface_hi(), 0.0)
    let pcx = bx + ctl_h() * 0.5
    let pcy = ctl_y + ctl_h() * 0.5
    ui_fill_rect(r, pcx - 5.0, pcy - 1.0, 10.0, 2.0, col_text(), 0.0)
    ui_fill_rect(r, pcx - 1.0, pcy - 5.0, 2.0, 10.0, col_text(), 0.0)
    if v.mouse_pressed {
        if g_click_used == false {
            if hit(v, bx, ctl_y, ctl_h(), ctl_h()) {
                add_attachment()
                g_click_used = true
            }
        }
    }
    bx = bx + ctl_h() + 10.0
    bx = draw_selector(r, v, bx, ctl_y, perm_label(g_perm), 1)
    bx = draw_selector(r, v, bx, ctl_y, module_label(g_module), 2)

    let sx = x + w - pad - send_d() + 2.0
    let sy = ctl_y - 2.0
    g_send_btn_x = sx
    g_send_btn_y = sy
    if g_running {
        ui_fill_round_rect(r, sx, sy, send_d(), send_d(), send_d() * 0.5, col_red(), 0.0)
        ui_fill_rect(r, sx + 10.0, sy + 10.0, 10.0, 10.0, col_bg(), 0.0)
    } else {
        let can_send = false
        if g_input_text != "" {
            can_send = true
        }
        if g_attach_count > 0 {
            can_send = true
        }
        let sbg = col_surface_hi()
        let sfg = col_muted()
        if can_send {
            sbg = col_accent()
            sfg = col_bg()
        }
        ui_fill_round_rect(r, sx, sy, send_d(), send_d(), send_d() * 0.5, sbg, 0.0)
        draw_send_arrow(r, sx + send_d() * 0.5, sy + send_d() * 0.5, sfg)
    }
    if v.mouse_pressed {
        if g_click_used == false {
            if hit(v, sx, sy, send_d(), send_d()) {
                g_click_used = true
                if g_running {
                    session_terminate()
                } else {
                    composer_send()
                }
            }
        }
    }
}

// ---- conversation pane ------------------------------------------------------------

// Codex-style agent view: the transcript flows down a centered column and the
// composer stays pinned at the bottom center of the pane.
fn draw_conversation(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    let header_h = 52.0
    let col_w = w - 48.0
    if col_w > 760.0 {
        col_w = 760.0
    }
    if col_w < 120.0 {
        col_w = w - 16.0
    }
    let col_x = x + (w - col_w) * 0.5

    let char_w = ui_mono_char_width(r, font_px(), FONT_MONO())
    if char_w <= 0.0 {
        char_w = font_px() * 0.6
    }

    // composer geometry first: the input grows with its wrapped line count
    let pad = 14.0
    let cols = ((col_w - pad * 2.0) / char_w) as i32
    if cols < 8 {
        cols = 8
    }
    let total_f = wrap_lines_f(g_input_text, cols)
    let shown_f = total_f
    if shown_f > 6.0 {
        shown_f = 6.0
    }
    let chips_h: f64 = 0.0
    if g_attach_count > 0 {
        chips_h = 32.0
    }
    let hint_h = 24.0
    let cmp_h = 12.0 + chips_h + shown_f * input_line_h() + 6.0 + 40.0
    g_cmp_x = col_x
    g_cmp_y = y + h - hint_h - cmp_h
    g_cmp_w = col_w
    g_cmp_h = cmp_h

    ui_fill_rect(r, x, y, w, h, col_agent_conversation(), 0.0)
    let pill_y = y + (header_h - 22.0) * 0.5
    if g_running {
        draw_pill(r, x + w - 118.0, pill_y, "running", col_surface(), col_yellow())
    } else {
        draw_pill(r, x + w - 118.0, pill_y, "ready", col_surface(), col_accent())
    }
    // transcript
    let body_y = y + header_h
    let body_h = g_cmp_y - body_y - 10.0
    let max_scroll = scroll_max(g_dialog_content_h, body_h)
    if hit(v, x, body_y, w, body_h) {
        g_dialog_scroll = clamp(g_dialog_scroll - v.scroll_y, 0.0, max_scroll)
        if v.mouse_pressed {
            if g_click_used == false {
                g_input_focus = false
            }
        }
    }

    let msg_cols = cols
    ui_push_clip(r, x, body_y, w, body_h)
    let yy = body_y + 16.0 - g_dialog_scroll
    if g_msg_count == 0 {
        draw_centered_text(r, col_x, body_y + body_h * 0.32, col_w, 22.0, "No conversations yet", font_px(), col_text())
        draw_centered_text(r, col_x, body_y + body_h * 0.32 + 25.0, col_w, 18.0, "Messages are stored in this project's .ns/chat", small_px(), col_muted())
    }
    for i in 0 to g_msg_count {
        let role = g_msg_role[i] as i32
        let text = g_msg_text[i]
        if role == ROLE_USER() {
            let bh = wrap_lines_f(text, msg_cols) * input_line_h() + 40.0
            ui_fill_round_rect(r, col_x, yy, col_w, bh, 8.0, col_surface(), 0.0)
            draw_label(r, col_x + pad, yy + 12.0, "YOU")
            draw_wrapped(r, col_x + pad, yy + 32.0, text, msg_cols, font_px(), col_text(), input_line_h())
            yy = yy + bh + 14.0
        } else if role == ROLE_AGENT() {
            ui_fill_circle(r, col_x + 5.0, yy + 11.0, 4.0, col_accent(), 0.5)
            draw_label(r, col_x + 18.0, text_center_y(r, yy, 22.0, small_px()), "NSCODE")
            let th = draw_wrapped(r, col_x + 18.0, yy + 26.0, text, msg_cols, font_px(), col_text(), input_line_h())
            yy = yy + th + 40.0
        } else {
            draw_centered_text(r, col_x, yy, col_w, 18.0, text, small_px(), col_muted())
            yy = yy + 30.0
        }
    }
    if g_running {
        ui_fill_circle(r, col_x + 5.0, yy + 11.0, 4.0, col_yellow(), 0.5)
        let dots = (((os_time() * 3.0) as i32) % 3) + 1
        let label = "working"
        for d in 0 to dots {
            label = label + "."
        }
        draw_text_clipped(r, col_x + 18.0, text_center_y(r, yy, 22.0, small_px()), 200.0, 16.0, label, small_px(), col_yellow())
        yy = yy + 30.0
    }
    ui_pop_clip(r)
    g_dialog_content_h = yy + g_dialog_scroll - body_y + 12.0
    if g_dialog_follow {
        g_dialog_follow = false
        g_dialog_scroll = scroll_max(g_dialog_content_h, body_h)
    }

    draw_composer(r, v, char_w, cols, shown_f, total_f, chips_h)
    draw_centered_text(r, col_x, g_cmp_y + cmp_h + 2.0, col_w, hint_h - 4.0, "enter to send / shift+enter for newline / saved in .ns/chat", small_px(), col_muted())
    if g_pop_kind != 0 {
        draw_popup(r, v)
    }
}

fn draw_status_bar(r: ref ui_renderer, x: f64, y: f64, w: f64) {
    ui_fill_rect(r, x, y, w, 28.0, col_status_bg(), 0.0)
    ui_fill_rect(r, x, y, w, 1.0, col_status_line(), 0.0)
    let ty = text_center_y(r, y, 28.0, small_px())
    ui_draw_text(r, x + 14.0, ty, setting_language_label() + " | " + setting_theme_label(), small_px(), col_status_text(), FONT_MONO())
    if w > 620.0 {
        ui_draw_text(r, x + w - 390.0, ty, "UI kernel in C, editor in NS", small_px(), col_status_text(), FONT_MONO())
        ui_draw_text(r, x + w - 120.0, ty, fps_text(), small_px(), col_status_text(), FONT_MONO())
    }
}

// ---- settings view ---------------------------------------------------------

fn SETTING_FONT() i32 { return 0 }
fn SETTING_SIZE() i32 { return 1 }
fn SETTING_THEME() i32 { return 2 }
fn SETTING_LANGUAGE() i32 { return 3 }

fn settings_panel_w(w: f64) f64 {
    let pw = w - 64.0
    if pw > 820.0 {
        pw = 820.0
    }
    if pw < 520.0 {
        pw = w - 24.0
    }
    return pw
}

fn settings_panel_x(w: f64) f64 {
    return (w - settings_panel_w(w)) * 0.5
}

fn settings_row_y(kind: i32) f64 {
    return main_menu_h() + 126.0 + (kind as f64) * 82.0
}

fn settings_option_count(kind: i32) i32 {
    if kind == SETTING_FONT() {
        return 2
    }
    return 3
}

fn settings_option_label(kind: i32, item: i32) str {
    if kind == SETTING_FONT() {
        if item == 0 {
            return "Sans UI"
        }
        return "Monospace"
    }
    if kind == SETTING_SIZE() {
        if item == 0 {
            return "Compact"
        }
        if item == 1 {
            return "Default"
        }
        return "Large"
    }
    if kind == SETTING_THEME() {
        if item == 0 {
            return "Dark"
        }
        if item == 1 {
            return "Light"
        }
        return "High Contrast"
    }
    if item == 0 {
        return "Nano Script"
    }
    if item == 1 {
        return "TypeScript"
    }
    return "Python"
}

fn settings_title(kind: i32) str {
    if kind == SETTING_FONT() {
        return "Interface font"
    }
    if kind == SETTING_SIZE() {
        return "Font size"
    }
    if kind == SETTING_THEME() {
        return "Theme"
    }
    return "Default language"
}

fn settings_detail(kind: i32) str {
    if kind == SETTING_FONT() {
        return "Code remains monospaced for exact cursor columns."
    }
    if kind == SETTING_SIZE() {
        return "Adjusts editor, chat, menus and spacing."
    }
    if kind == SETTING_THEME() {
        return "Changes every app surface immediately."
    }
    return "Controls syntax palette and the active language preference."
}

fn settings_current(kind: i32) i32 {
    if kind == SETTING_FONT() {
        return g_setting_font_family
    }
    if kind == SETTING_SIZE() {
        return g_setting_font_size
    }
    if kind == SETTING_THEME() {
        return g_setting_theme
    }
    return g_setting_language
}

fn settings_set(kind: i32, item: i32) {
    if kind == SETTING_FONT() {
        g_setting_font_family = clamp_i(item, 0, 1)
    } else if kind == SETTING_SIZE() {
        g_setting_font_size = clamp_i(item, 0, 2)
    } else if kind == SETTING_THEME() {
        g_setting_theme = clamp_i(item, 0, 2)
    } else {
        g_setting_language = clamp_i(item, 0, 2)
        set_syntax_language(g_setting_language)
    }
    settings_save()
}

fn settings_segment_x(w: f64) f64 {
    return settings_panel_x(w) + 270.0
}

fn settings_segment_w(w: f64) f64 {
    return settings_panel_w(w) - 302.0
}

fn settings_option_x(w: f64, kind: i32, item: i32) f64 {
    return settings_segment_x(w) + settings_segment_w(w) * (item as f64) / (settings_option_count(kind) as f64)
}

fn settings_option_w(w: f64, kind: i32) f64 {
    return settings_segment_w(w) / (settings_option_count(kind) as f64)
}

fn draw_settings_row(r: ref ui_renderer, v: ref view, w: f64, kind: i32) {
    let px = settings_panel_x(w)
    let pw = settings_panel_w(w)
    let y = settings_row_y(kind)
    ui_fill_round_rect(r, px, y, pw, 68.0, 8.0, col_surface(), 0.0)
    ui_stroke_round_rect(r, px, y, pw, 68.0, 8.0, 1.0, col_line(), 0.0)
    ui_draw_text(r, px + 20.0, y + 12.0, settings_title(kind), font_px(), col_text(), FONT_MONO())
    draw_text_clipped(r, px + 20.0, y + 37.0, 232.0, 18.0, settings_detail(kind), small_px(), col_muted())

    let count = settings_option_count(kind)
    let sy = y + 16.0
    let sh = 36.0
    ui_fill_round_rect(r, settings_segment_x(w), sy, settings_segment_w(w), sh, 6.0, col_rail(), 0.0)
    for item in 0 to count {
        let ox = settings_option_x(w, kind, item)
        let ow = settings_option_w(w, kind)
        let active = settings_current(kind) == item
        if active {
            ui_fill_round_rect(r, ox + 2.0, sy + 2.0, ow - 4.0, sh - 4.0, 4.0, col_accent(), 0.0)
        } else if hit(v, ox, sy, ow, sh) {
            ui_fill_round_rect(r, ox + 2.0, sy + 2.0, ow - 4.0, sh - 4.0, 4.0, col_surface_hi(), 0.0)
        }
        let fg = col_text()
        if active {
            fg = col_bg()
        }
        draw_centered_text(r, ox, sy, ow, sh, settings_option_label(kind, item), small_px(), fg)
        if v.mouse_pressed {
            if hit(v, ox, sy, ow, sh) {
                settings_set(kind, item)
                v.mouse_pressed = false
                v.mouse_down = false
            }
        }
    }
}

fn settings_done_x(w: f64) f64 {
    return settings_panel_x(w) + settings_panel_w(w) - 92.0
}

fn render_settings(r: ref ui_renderer, v: ref view, w: f64, h: f64) {
    let status_h = 28.0
    let app_y = main_menu_h()
    ui_fill_rect(r, 0.0, app_y, w, h - app_y - status_h, col_bg(), 0.0)
    let px = settings_panel_x(w)
    ui_draw_text(r, px, app_y + 32.0, "Settings", 24.0, col_text(), FONT_MONO())
    ui_draw_text(r, px, app_y + 68.0, "Global NSCode preferences", small_px(), col_muted(), FONT_MONO())

    let dx = settings_done_x(w)
    let dy = app_y + 28.0
    if hit(v, dx, dy, 92.0, 34.0) {
        ui_fill_round_rect(r, dx, dy, 92.0, 34.0, 6.0, col_surface_hi(), 0.0)
    } else {
        ui_fill_round_rect(r, dx, dy, 92.0, 34.0, 6.0, col_surface(), 0.0)
    }
    draw_centered_text(r, dx, dy, 92.0, 34.0, "Done", small_px(), col_text())
    if v.mouse_pressed {
        if hit(v, dx, dy, 92.0, 34.0) {
            g_mode = g_settings_return_mode
            v.mouse_pressed = false
            v.mouse_down = false
        }
    }

    for kind in 0 to 4 {
        draw_settings_row(r, v, w, kind)
    }
    draw_status_bar(r, 0.0, h - status_h, w)
}

// ---- code view input -------------------------------------------------------

fn shift_down(v: ref view) bool {
    if view_is_key_pressed(v, 340) {
        return true
    }
    if view_is_key_pressed(v, 344) {
        return true
    }
    return false
}

// Control or Command (super), so shortcuts work on both Windows and macOS.
let g_key_event_mods: i32 = 0

fn key_event_shift() bool {
    return (g_key_event_mods & 1) != 0
}

fn key_event_cmd() bool {
    if (g_key_event_mods & 2) != 0 {
        return true
    }
    return (g_key_event_mods & 8) != 0
}

// Consume one native-latched key-down edge. The event retains the modifiers
// that were active at keyDown time even if keyUp happens before this frame.
fn key_edge(v: ref view, k: i32) bool {
    let mods = view_take_key_press(v, k)
    if mods >= 0 {
        g_key_event_mods = mods
        return true
    }
    return false
}

// Poll keyboard state and apply edits/navigation to the document. Marks the
// caret to be scrolled into view when anything happened.
fn process_code_keys(v: ref view) {
    set_shift(shift_down(v))

    // Structural and navigation keys: enter(257), backspace(259), delete(261),
    // arrows/home/end/page (262..269). Tab(258) and insert(260) are skipped.
    for k in 257 to 270 {
        if k != 258 {
            if k != 260 {
                if key_edge(v, k) {
                    if key_event_cmd() == false {
                        set_shift(key_event_shift())
                        process_view_key(k)
                        g_caret_follow = true
                    }
                }
            }
        }
    }

    if key_edge(v, 258) {
        if key_event_cmd() == false {
            insert_tab()
            g_caret_follow = true
        }
    }

    // Printable keys and shortcuts share the same latched event path. This is
    // what makes a fast Cmd+Z reliable even when both key transitions occur
    // between two rendered frames.
    for k in 32 to 97 {
        if key_edge(v, k) {
            let shifted = key_event_shift()
            if key_event_cmd() {
                if k == 90 {
                    if shifted {
                        redo()
                    } else {
                        undo()
                    }
                    g_caret_follow = true
                } else if k == 89 {
                    redo()
                    g_caret_follow = true
                } else if k == 65 {
                    select_all()
                } else if k == 67 {
                    if has_selection() {
                        view_set_clipboard(v, selected_text())
                    }
                } else if k == 88 {
                    if has_selection() {
                        view_set_clipboard(v, selected_text())
                        delete_selection()
                        g_caret_follow = true
                    }
                } else if k == 86 {
                    let clip = view_get_clipboard(v)
                    if clip != "" {
                        paste_str(clip)
                        g_caret_follow = true
                    }
                } else if k == 83 {
                    workspace_save_active()
                } else if k == 87 {
                    if g_workspace_active >= 0 {
                        workspace_close_tab(g_workspace_active)
                        g_caret_follow = true
                    }
                }
            } else {
                let c = key_char(k, shifted)
                if c != "" {
                    insert_str(c)
                    g_caret_follow = true
                }
            }
        }
    }
}

fn mouse_line(v: ref view, body_y: f64, line_h: f64) i32 {
    let fy = (v.mouse_y - body_y - 18.0 + g_code_scroll) / line_h
    if fy < 0.0 {
        return 0
    }
    return fy as i32
}

fn mouse_col(v: ref view, text_x: f64, char_w: f64) i32 {
    let fx = (v.mouse_x - text_x) / char_w + 0.5
    if fx < 0.0 {
        return 0
    }
    return fx as i32
}

// Click places the caret, drag extends the selection, double click selects the
// word and triple click the whole line.
fn process_code_mouse(v: ref view, x: f64, body_y: f64, w: f64, body_h: f64, text_x: f64, line_h: f64, char_w: f64) {
    if v.mouse_pressed {
        if hit(v, x, body_y, w, body_h) {
            let li = mouse_line(v, body_y, line_h)
            let col = mouse_col(v, text_x, char_w)
            let now = os_time()
            let streak: i32 = 1
            if (now - g_last_click_time) < 0.45 {
                if li == g_last_click_line {
                    streak = g_click_streak + 1
                }
            }
            g_click_streak = streak
            g_last_click_time = now
            g_last_click_line = li
            if streak >= 3 {
                select_line(li)
                g_code_drag = false
            } else if streak == 2 {
                select_word_at(li, col)
                g_code_drag = false
            } else {
                place_cursor(li, col, shift_down(v))
                g_code_drag = true
            }
        }
    }
    if g_code_drag {
        if v.mouse_down {
            place_cursor(mouse_line(v, body_y, line_h), mouse_col(v, text_x, char_w), true)
        }
    }
    if v.mouse_released {
        g_code_drag = false
    }
}

// Adjust g_code_scroll so the caret line is visible inside the body.
fn follow_caret(body_h: f64, line_h: f64, max_scroll: f64) {
    let top = (cur_line() as f64) * line_h
    let bot = top + line_h + 26.0
    if top < g_code_scroll {
        g_code_scroll = top
    }
    if bot > (g_code_scroll + body_h) {
        g_code_scroll = bot - body_h
    }
    g_code_scroll = clamp(g_code_scroll, 0.0, max_scroll)
}

// One syntax-highlighted document line at the mono grid position (text_x, row_y).
fn draw_code_line(r: ref ui_renderer, li: i32, text_x: f64, row_y: f64, char_w: f64, first_col: i32, cols: i32) {
    let n = tokenize_line(li)
    let view_end = first_col + cols
    for t in 0 to n {
        let ts = token_start(t)
        let te = ts + token_len(t)
        if te > first_col {
            if ts < view_end {
                let ds = ts
                if ds < first_col {
                    ds = first_col
                }
                let de = te
                if de > view_end {
                    de = view_end
                }
                let tx = text_x + ((ds - first_col) as f64) * char_w
                ui_draw_text(r, tx, row_y, token_text_part(t, ds - ts, de - ds), code_font_px(), token_color(token_kind(t)), CODE_FONT())
            }
        }
    }
}

fn code_minimap_w(editor_w: f64) f64 {
    if editor_w < 420.0 {
        return 56.0
    }
    if editor_w < 680.0 {
        return 68.0
    }
    return 82.0
}

fn code_gutter_w() f64 { return 52.0 }
fn code_text_inset() f64 { return 12.0 }

fn code_line_number_x(r: ref ui_renderer, editor_x: f64, text: str) f64 {
    return editor_x + code_gutter_w() - 10.0 - ui_text_width(r, text, small_px(), FONT_MONO())
}

fn minimap_line_step(total: i32, body_h: f64) f64 {
    return 2.0
}

fn minimap_scroll_to_mouse(v: ref view, total: i32, body_h: f64, line_h: f64, max_scroll: f64) {
    let step = minimap_line_step(total, body_h)
    let visible_lines = body_h / line_h
    let target_line = (v.mouse_y - g_minimap_y + g_minimap_scroll) / step
    let target = (target_line - visible_lines * 0.5) * line_h
    g_code_scroll = clamp(target, 0.0, max_scroll)
    g_caret_follow = false
}

fn process_minimap_mouse(v: ref view, total: i32, body_h: f64, line_h: f64, max_scroll: f64) {
    if v.mouse_pressed {
        if hit(v, g_minimap_x, g_minimap_y, g_minimap_w, g_minimap_h) {
            g_minimap_drag = true
            g_code_drag = false
            minimap_scroll_to_mouse(v, total, body_h, line_h, max_scroll)
            // The minimap owns this press; do not let tab/editor click handlers
            // observe the same edge.
            v.mouse_pressed = false
        }
    }
    if g_minimap_drag {
        if v.mouse_down {
            minimap_scroll_to_mouse(v, total, body_h, line_h, max_scroll)
        }
    }
    if v.mouse_released {
        g_minimap_drag = false
    }
}

fn minimap_batch_changed(total: i32, body_h: f64) bool {
    if g_minimap_batch == 0 || g_minimap_batch_ready == false {
        return true
    }
    if g_minimap_batch_doc_version != g_doc_version || g_minimap_batch_total != total {
        return true
    }
    if g_minimap_batch_language != g_setting_language {
        return true
    }
    if g_minimap_batch_w != g_minimap_w {
        return true
    }
    return false
}

// Emit the original minimap geometry either into a retained GPU batch or into
// the immediate renderer as a fallback. Sampling, token positions and colors
// intentionally match the original minimap exactly.
fn emit_code_minimap_tokens(r: ref ui_renderer, batch: i32, origin_x: f64, origin_y: f64, body_h: f64, total: i32) {
    let step = minimap_line_step(total, body_h)
    let char_scale = clamp((g_minimap_w - 12.0) / 100.0, 0.45, 0.9)
    let block_h = clamp(step * 0.68, 0.45, 1.6)
    let right = origin_x + g_minimap_w - 5.0
    let li: i32 = 0
    loop li < total {
        let row_y = origin_y + (li as f64) * step
        let n = tokenize_line(li)
        for t in 0 to n {
            let bx = origin_x + 6.0 + (token_start(t) as f64) * char_scale
            if bx < right {
                let bw = (token_len(t) as f64) * char_scale
                if bw < 1.0 {
                    bw = 1.0
                }
                if bx + bw > right {
                    bw = right - bx
                }
                if bw > 0.0 {
                    let color = minimap_token_color(token_kind(t))
                    if batch > 0 {
                        ui_rect_batch_add(r, batch, bx, row_y, bw, block_h, color)
                    } else {
                        ui_fill_rect(r, bx, row_y, bw, block_h, color, 0.0)
                    }
                }
            }
        }
        li = li + 1
    }
}

fn rebuild_code_minimap_batch(r: ref ui_renderer, body_h: f64, total: i32) bool {
    if g_minimap_batch == 0 {
        g_minimap_batch = ui_rect_batch_create(r)
    }
    if g_minimap_batch == 0 {
        return false
    }
    ui_rect_batch_begin(r, g_minimap_batch)
    emit_code_minimap_tokens(r, g_minimap_batch, 0.0, 0.0, body_h, total)
    g_minimap_batch_ready = ui_rect_batch_end(r, g_minimap_batch)
    g_minimap_batch_doc_version = g_doc_version
    g_minimap_batch_total = total
    g_minimap_batch_language = g_setting_language
    g_minimap_batch_w = g_minimap_w
    g_minimap_batch_build_count = g_minimap_batch_build_count + 1
    g_minimap_last_code_scroll = -1.0
    return g_minimap_batch_ready
}

fn sync_minimap_scroll(total: i32, body_h: f64, line_h: f64) {
    let step = minimap_line_step(total, body_h)
    let content_h = (total as f64) * step
    let max_scroll = scroll_max(content_h, g_minimap_h)
    g_minimap_scroll = clamp(g_minimap_scroll, 0.0, max_scroll)
    if g_minimap_last_code_scroll != g_code_scroll {
        let view_top = (g_code_scroll / line_h) * step
        let view_h = (body_h / line_h) * step
        if view_top < g_minimap_scroll {
            g_minimap_scroll = view_top
        } else if view_top + view_h > g_minimap_scroll + g_minimap_h {
            g_minimap_scroll = view_top + view_h - g_minimap_h
        }
        g_minimap_scroll = clamp(g_minimap_scroll, 0.0, max_scroll)
        g_minimap_last_code_scroll = g_code_scroll
    }
}

fn draw_code_minimap(r: ref ui_renderer, body_h: f64, total: i32, line_h: f64) {
    ui_fill_rect(r, g_minimap_x, g_minimap_y - 4.0, g_minimap_w, body_h, col_minimap_bg(), 0.0)
    ui_push_clip(r, g_minimap_x, g_minimap_y, g_minimap_w, g_minimap_h)

    if minimap_batch_changed(total, body_h) {
        rebuild_code_minimap_batch(r, body_h, total)
    }
    sync_minimap_scroll(total, body_h, line_h)
    if g_minimap_batch_ready {
        ui_rect_batch_draw_at(r, g_minimap_batch, g_minimap_x, g_minimap_y - g_minimap_scroll)
    } else {
        emit_code_minimap_tokens(r, 0, g_minimap_x, g_minimap_y - g_minimap_scroll, body_h, total)
    }

    let step = minimap_line_step(total, body_h)
    let content_h = (total as f64) * step
    let viewport_h = (body_h / line_h) * step
    if viewport_h < 8.0 {
        viewport_h = 8.0
    }
    if viewport_h > content_h {
        viewport_h = content_h
    }
    if viewport_h > g_minimap_h {
        viewport_h = g_minimap_h
    }
    let viewport_y = g_minimap_y + (g_code_scroll / line_h) * step - g_minimap_scroll
    g_minimap_view_y = viewport_y
    g_minimap_view_h = viewport_h
    ui_fill_rect(r, g_minimap_x + 2.0, viewport_y, g_minimap_w - 4.0, viewport_h, col_minimap_view(), 0.0)
    ui_pop_clip(r)
}

fn file_tree_width(w: f64) f64 {
    if w < 700.0 {
        return 176.0
    }
    if w < 900.0 {
        return 208.0
    }
    return 244.0
}

fn tree_row_h() f64 { return 26.0 }

fn workspace_visible_height() f64 {
    workspace_rebuild_visible()
    return (g_workspace_visible_count as f64) * tree_row_h()
}

fn activate_workspace_file(index: i32) {
    let previous = g_workspace_active
    if previous >= 0 {
        g_file_scroll[previous] = g_code_scroll
    }
    if workspace_open(index) {
        g_code_scroll = g_file_scroll[index]
        g_caret_follow = true
        g_code_drag = false
        g_last_click_line = -1
        g_click_streak = 0
    }
}

fn draw_tree_arrow(r: ref ui_renderer, x: f64, y: f64, expanded: bool, color: u32) {
    let thickness = 1.8
    let radius = thickness * 0.5
    if expanded {
        draw_chevron_down(r, x + 4.5, y + 4.6, color)
    } else {
        ui_stroke_line(r, x + 2.5, y + 1.5, x + 5.7, y + 4.7, thickness, color, 0.5)
        ui_stroke_line(r, x + 5.7, y + 4.7, x + 2.5, y + 7.9, thickness, color, 0.5)
        ui_fill_circle(r, x + 2.5, y + 1.5, radius, color, 0.5)
        ui_fill_circle(r, x + 5.7, y + 4.7, radius, color, 0.5)
        ui_fill_circle(r, x + 2.5, y + 7.9, radius, color, 0.5)
    }
}

fn draw_tree_folder_icon(r: ref ui_renderer, x: f64, y: f64, color: u32) {
    // Recess the tab slightly and darken its stroke so it reads as a separate
    // back plate instead of merging into the filled folder body.
    ui_fill_round_rect(r, x + 1.5, y + 2.0, 7.0, 5.0, 2.0, ui_pack_color("#465663"), 0.5)
    ui_fill_round_rect(r, x, y + 5.0, 15.0, 10.0, 2.0, color, 0.5)
}

fn draw_tree_file_icon(r: ref ui_renderer, x: f64, y: f64, color: u32) {
    ui_stroke_rect(r, x + 2.0, y + 1.0, 10.0, 14.0, 1.0, color, 0.0)
    ui_stroke_line(r, x + 5.0, y + 6.0, x + 10.0, y + 6.0, 1.0, color, 0.0)
    ui_stroke_line(r, x + 5.0, y + 9.0, x + 10.0, y + 9.0, 1.0, color, 0.0)
}

fn draw_workspace_file_icon(r: ref ui_renderer, x: f64, y: f64) {
    let atlas: i32 = g_file_icon_atlas
    ui_atlas_draw(r, atlas, x, y, 16.0, 16.0)
}

fn draw_explorer_action(r: ref ui_renderer, v: ref view, x: f64, y: f64, kind: i32) bool {
    let hot = hit(v, x, y, 22.0, 22.0)
    if hot {
        ui_fill_round_rect(r, x, y, 22.0, 22.0, 4.0, col_surface_hi(), 0.0)
    }
    let color = col_muted()
    if hot {
        color = col_text()
    }
    if kind == 0 {
        ui_stroke_round_rect(r, x + 5.0, y + 3.5, 12.0, 15.0, 2.0, 1.2, color, 0.0)
        ui_fill_round_rect(r, x + 7.5, y + 8.0, 7.0, 1.2, 0.6, color, 0.0)
        ui_fill_round_rect(r, x + 7.5, y + 11.5, 7.0, 1.2, 0.6, color, 0.0)
    } else if kind == 1 {
        draw_tree_folder_icon(r, x + 3.0, y + 2.0, color)
    } else if kind == 2 {
        ui_stroke_round_rect(r, x + 5.0, y + 5.0, 12.0, 12.0, 2.0, 1.5, color, 0.0)
        let arrow_thickness = 1.8
        let arrow_radius = arrow_thickness * 0.5
        ui_stroke_line(r, x + 13.0, y + 9.25, x + 16.5, y + 12.75, arrow_thickness, color, 0.5)
        ui_stroke_line(r, x + 16.5, y + 12.75, x + 20.0, y + 9.25, arrow_thickness, color, 0.5)
        ui_fill_circle(r, x + 13.0, y + 9.25, arrow_radius, color, 0.5)
        ui_fill_circle(r, x + 16.5, y + 12.75, arrow_radius, color, 0.5)
        ui_fill_circle(r, x + 20.0, y + 9.25, arrow_radius, color, 0.5)
    } else {
        ui_stroke_line(r, x + 5.0, y + 7.0, x + 11.0, y + 12.0, 1.5, color, 0.5)
        ui_stroke_line(r, x + 17.0, y + 7.0, x + 11.0, y + 12.0, 1.5, color, 0.5)
        ui_stroke_line(r, x + 5.0, y + 12.0, x + 11.0, y + 17.0, 1.5, color, 0.5)
        ui_stroke_line(r, x + 17.0, y + 12.0, x + 11.0, y + 17.0, 1.5, color, 0.5)
    }
    return hot && v.mouse_pressed
}

fn draw_file_tree(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    let header_h = 42.0
    let root_h = 30.0
    let list_y = y + header_h + root_h
    let list_h = h - header_h - root_h

    ui_fill_rect(r, x, y, w, h, col_editor_panel(), 0.0)
    draw_text_clipped(r, x + 14.0, text_center_y(r, y, header_h, small_px()), w - 122.0, 16.0, "EXPLORER", small_px(), col_muted())
    let action_y = y + 10.0
    let action_x = x + w - 102.0
    let action = -1
    for kind in 0 to 4 {
        if draw_explorer_action(r, v, action_x + (kind as f64) * 24.0, action_y, kind) {
            action = kind
        }
    }
    if action == 0 {
        workspace_create_file()
    } else if action == 1 {
        workspace_create_folder()
    } else if action == 2 {
        workspace_refresh_from_disk()
    } else if action == 3 {
        workspace_collapse_all()
        g_tree_scroll = 0.0
    }
    if action >= 0 {
        v.mouse_pressed = false
    }

    let root_hover = hit(v, x, y + header_h, w, root_h)
    if root_hover {
        ui_fill_rect(r, x, y + header_h, w - 1.0, root_h, col_editor_panel_hi(), 0.0)
    }
    draw_tree_arrow(r, x + 12.0, y + header_h + 10.0, g_workspace_root_expanded, col_text())
    draw_tree_folder_icon(r, x + 28.0, y + header_h + 7.0, col_accent())
    draw_text_clipped(r, x + 50.0, text_center_y(r, y + header_h, root_h, small_px()), w - 60.0, 16.0, workspace_root_name(g_workspace_root), small_px(), col_text())
    if v.mouse_pressed {
        if root_hover {
            g_workspace_root_expanded = g_workspace_root_expanded == false
            workspace_mark_visibility_dirty()
        }
    }

    let content_h = workspace_visible_height()
    let max_scroll = scroll_max(content_h, list_h)
    if hit(v, x, list_y, w, list_h) {
        g_tree_scroll = clamp(g_tree_scroll - v.scroll_y, 0.0, max_scroll)
    }
    g_tree_scroll = clamp(g_tree_scroll, 0.0, max_scroll)

    ui_push_clip(r, x, list_y, w - 1.0, list_h)
    let first_row = (g_tree_scroll / tree_row_h()) as i32
    if first_row < 0 {
        first_row = 0
    }
    let last_row = first_row + (list_h / tree_row_h()) as i32 + 2
    if last_row > g_workspace_visible_count {
        last_row = g_workspace_visible_count
    }
    let row_y = list_y + (first_row as f64) * tree_row_h() - g_tree_scroll
    for visible_pos in first_row to last_row {
        let i = g_workspace_visible[visible_pos] as i32
                    let hovered = hit(v, x, row_y, w - 1.0, tree_row_h())
                    if i == g_workspace_active {
                        ui_fill_rect(r, x, row_y, w - 1.0, tree_row_h(), col_editor_panel_hi(), 0.0)
                        ui_fill_rect(r, x, row_y, 2.0, tree_row_h(), col_accent(), 0.0)
                    } else if hovered {
                        ui_fill_rect(r, x, row_y, w - 1.0, tree_row_h(), col_surface_hi(), 0.0)
                    }

                    let depth = os_entry_depth(i) & 255
                    let depth_f: f64 = 0.0
                    loop depth > 0 {
                        depth_f = depth_f + 1.0
                        depth = depth - 1
                    }
                    let indent = x + 14.0 + depth_f * 16.0
                    let icon_color = col_blue()
                    if workspace_entry_editable(i) == false {
                        icon_color = col_muted()
                    }
                    if os_entry_is_dir(i) != 0 {
                        draw_tree_arrow(r, indent, row_y + 8.0, workspace_entry_expanded(i), col_muted())
                        draw_tree_folder_icon(r, indent + 15.0, row_y + 6.0, col_blue())
                    } else {
                        draw_workspace_file_icon(r, indent + 14.0, row_y + 5.0)
                    }
                    draw_text_clipped(r, indent + 38.0, text_center_y(r, row_y, tree_row_h(), small_px()), w - (indent - x) - 54.0, 16.0, os_entry_name(i), small_px(), icon_color)
                    if workspace_entry_dirty(i) {
                        ui_fill_circle(r, x + w - 12.0, row_y + tree_row_h() * 0.5, 3.0, col_yellow(), 0.0)
                    }
                    if v.mouse_pressed {
                        if hovered {
                            if os_entry_is_dir(i) != 0 {
                                workspace_toggle_entry(i)
                            } else {
                                activate_workspace_file(i)
                            }
                        }
                    }
        row_y = row_y + tree_row_h()
    }
    ui_pop_clip(r)
}

fn draw_code_editor(r: ref ui_renderer, v: ref view, x: f64, y: f64, w: f64, h: f64) {
    let tab_h = 36.0
    let line_h = code_line_h()
    let body_y = y + tab_h
    let body_h = h - tab_h
    let gutter_w = code_gutter_w()
    let minimap_w = code_minimap_w(w)
    let code_w = w - minimap_w

    let char_w = ui_mono_char_width(r, code_font_px(), CODE_FONT())
    if char_w <= 0.0 {
        char_w = code_font_px() * 0.6
    }
    let text_x = x + gutter_w + code_text_inset()
    let text_w = code_w - gutter_w - code_text_inset() - 8.0
    let visible_cols = (text_w / char_w) as i32 + 1

    let total = line_count()
    let content_h = (total as f64) * line_h + 40.0
    let max_scroll = scroll_max(content_h, body_h)
    g_minimap_x = x + code_w
    g_minimap_y = body_y + 4.0
    g_minimap_w = minimap_w
    g_minimap_h = body_h - 8.0

    let minimap_content_h = (total as f64) * minimap_line_step(total, body_h)
    let minimap_max_scroll = scroll_max(minimap_content_h, g_minimap_h)
    if hit(v, g_minimap_x, g_minimap_y, g_minimap_w, g_minimap_h) {
        g_minimap_scroll = clamp(g_minimap_scroll - v.scroll_y * code_wheel_scale(), 0.0, minimap_max_scroll)
    }
    process_minimap_mouse(v, total, body_h, line_h, max_scroll)
    process_code_mouse(v, x, body_y, code_w, body_h, text_x, line_h, char_w)
    process_code_keys(v)
    if hit(v, x, body_y, code_w, body_h) {
        g_code_scroll = clamp(g_code_scroll - v.scroll_y * code_wheel_scale(), 0.0, max_scroll)
    }
    if g_caret_follow {
        g_caret_follow = false
        follow_caret(body_h, line_h, max_scroll)
    }
    g_code_scroll = clamp(g_code_scroll, 0.0, max_scroll)

    ui_fill_rect(r, x, y, w, h, col_editor_bg(), 0.0)
    ui_fill_rect(r, x, y, w, tab_h, col_editor_panel(), 0.0)
    let tab_x = x + 14.0
    ui_push_clip(r, x, y, w, tab_h)
    for ti in 0 to g_workspace_tab_count {
        let tab_index = g_workspace_tabs[ti] as i32
        let tab_name = os_entry_name(tab_index)
        let dirty = workspace_entry_dirty(tab_index)
        let tab_w = ui_text_width(r, tab_name, small_px(), FONT_MONO()) + 72.0
        if tab_w < 132.0 {
            tab_w = 132.0
        }
        if tab_w > 240.0 {
            tab_w = 240.0
        }
        let active = tab_index == g_workspace_active
        let tab_bg = col_editor_tab()
        if active {
            tab_bg = col_editor_panel_hi()
        } else if hit(v, tab_x, y + 7.0, tab_w, 29.0) {
            tab_bg = ui_pack_color("#232a34")
        }
        ui_fill_round_rect(r, tab_x, y + 7.0, tab_w, 29.0, 5.0, tab_bg, 0.0)
        // Keep only the two top corners rounded: the tab joins the editor body.
        ui_fill_rect(r, tab_x, y + 31.0, tab_w, 5.0, tab_bg, 0.0)
        draw_tree_file_icon(r, tab_x + 12.0, y + 14.0, col_blue())
        draw_text_clipped(r, tab_x + 34.0, text_center_y(r, y + 7.0, 29.0, small_px()), tab_w - 62.0, 16.0, tab_name, small_px(), col_text())
        let close_cx = tab_x + tab_w - 18.0
        let close_cy = y + 21.5
        let close_hot = hit(v, close_cx - 10.0, close_cy - 10.0, 20.0, 20.0)
        if close_hot {
            ui_fill_circle(r, close_cx, close_cy, 9.0, col_surface(), 0.0)
        }
        if dirty {
            if close_hot == false {
                ui_fill_circle(r, close_cx, close_cy, 4.0, col_muted(), 0.0)
            }
        }
        if dirty == false || close_hot {
            ui_stroke_line(r, close_cx - 4.0, close_cy - 4.0, close_cx + 4.0, close_cy + 4.0, 1.2, col_muted(), 0.5)
            ui_stroke_line(r, close_cx - 4.0, close_cy + 4.0, close_cx + 4.0, close_cy - 4.0, 1.2, col_muted(), 0.5)
        }
        if v.mouse_pressed {
            if close_hot {
                workspace_close_tab(tab_index)
            } else if hit(v, tab_x, y + 7.0, tab_w, 29.0) {
                activate_workspace_file(tab_index)
            }
        }
        tab_x = tab_x + tab_w + 2.0
    }
    ui_pop_clip(r)

    // Repaint with the same color as the code canvas. There is intentionally no
    // gutter edge/stroke, so the number bar and source area read as one surface.
    ui_fill_rect(r, x, body_y, gutter_w, body_h, col_editor_gutter(), 0.0)
    let first = ((g_code_scroll - 18.0 - line_h) / line_h) as i32
    if first < 0 {
        first = 0
    }
    let last = ((g_code_scroll + body_h - 18.0) / line_h) as i32 + 2
    if last > total {
        last = total
    }

    let cursor_line = cur_line()
    let cursor_col = cur_col()
    let selected = has_selection()
    ui_push_clip(r, x, body_y, code_w, body_h)
    for i in first to last {
        // Row rect (row_top, line_h) matches the mouse_line hit mapping; the
        // text y inside it comes from text_center_y so the glyphs sit mid-row.
        let row_top = body_y + 18.0 + (i as f64) * line_h - g_code_scroll
        if row_top + line_h >= body_y {
            if row_top <= body_y + body_h {
                if i == cursor_line {
                    ui_fill_rect(r, x, row_top, code_w, line_h, col_editor_panel(), 0.0)
                }
                if selected {
                    let sb = line_sel_begin(i)
                    if sb >= 0 {
                        let se = line_sel_end(i)
                        let ss = sb
                        if ss < g_coloff {
                            ss = g_coloff
                        }
                        let ee = se
                        let col_end = g_coloff + visible_cols
                        if ee > col_end {
                            ee = col_end
                        }
                        if ee > ss {
                            let sel_x = text_x + ((ss - g_coloff) as f64) * char_w
                            let sel_w = ((ee - ss) as f64) * char_w
                            ui_fill_rect(r, sel_x, row_top, sel_w, line_h, col_editor_sel(), 0.0)
                        }
                    }
                }
                let num_color = col_muted()
                if i == cursor_line {
                    num_color = col_text()
                }
                let line_number = itos(i + 1)
                let line_number_x = code_line_number_x(r, x, line_number)
                draw_text_clipped(r, line_number_x, text_center_y(r, row_top, line_h, small_px()), gutter_w - (line_number_x - x) - 10.0, 18.0, line_number, small_px(), num_color)
                ui_push_clip(r, text_x, body_y, text_w, body_h)
                draw_code_line(r, i, text_x, text_center_y(r, row_top, line_h, code_font_px()), char_w, g_coloff, visible_cols)
                ui_pop_clip(r)
            }
        }
    }
    let cursor_x = text_x + ((cursor_col - g_coloff) as f64) * char_w
    let cursor_top = body_y + 18.0 + (cursor_line as f64) * line_h - g_code_scroll
    ui_fill_rect(r, cursor_x, cursor_top + 2.0, 2.0, line_h - 4.0, col_editor_cursor(), 0.0)
    ui_pop_clip(r)
    draw_code_minimap(r, body_h, total, line_h)
}

fn render_code(r: ref ui_renderer, v: ref view, w: f64, h: f64) {
    let status_h = 28.0
    let app_y = main_menu_h()
    let app_h = h - status_h - app_y
    let tree_w = file_tree_width(w)

    ui_fill_rect(r, 0.0, 0.0, w, h, col_editor_bg(), 0.0)
    draw_file_tree(r, v, 0.0, app_y, tree_w, app_h)
    draw_code_editor(r, v, tree_w, app_y, w - tree_w, app_h)
    draw_mode_switch(r, v, mode_switch_x(w), mode_switch_y(h), 150.0, 28.0)
    draw_status_bar(r, 0.0, h - status_h, w)
}

fn history_width(w: f64) f64 {
    if w < 740.0 {
        return 180.0
    }
    if w < 980.0 {
        return 214.0
    }
    return 276.0
}

fn render_agent(r: ref ui_renderer, v: ref view, w: f64, h: f64) {
    let status_h = 28.0
    let app_y = main_menu_h()
    let app_h = h - status_h - app_y
    let history_w = history_width(w)

    if g_chat_store_loaded == false {
        chat_load_project()
    }
    handle_popup_input(v)
    handle_chat_menu_input(v)
    process_composer_keys(v)

    ui_fill_rect(r, 0.0, 0.0, w, h, col_bg(), 0.0)
    draw_history(r, v, 0.0, app_y, history_w, app_h)
    draw_conversation(r, v, history_w, app_y, w - history_w, app_h)
    draw_mode_switch(r, v, mode_switch_x(w), mode_switch_y(h), 150.0, 28.0)
    draw_status_bar(r, 0.0, h - status_h, w)
}

fn render_frame(r: ref ui_renderer, v: ref view) {
    update_fps()
    workspace_poll_changes()
    ui_resize(r)
    // ref-fn i32 returns can carry garbage upper bits (same class of quirk as
    // the masked byte reads in editor.ns), which poisons f64 arithmetic on the
    // cast value; mask to a sane canvas range first.
    let w = (ui_canvas_width(r) & 1048575) as f64
    let h = (ui_canvas_height(r) & 1048575) as f64
    sync_ui_focus()
    handle_main_menu_input(r, v, w)
    handle_mode_switch_input(v, w, h)
    if g_mode == MODE_CODE() {
        render_code(r, v, w, h)
    } else if g_mode == MODE_AGENT() {
        render_agent(r, v, w, h)
    } else {
        render_settings(r, v, w, h)
    }
    draw_main_menu(r, v, w)
}
