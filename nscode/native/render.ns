let g_pop_x: f64 = 0.0
let g_pop_y: f64 = 0.0
let g_pop_w: f64 = 0.0

// Chat history model: titles and pinned flags live in i32-keyed stores (same
// string-array workaround as the transcript). Each chat owns a fixed message
// block, and the complete model is persisted under <project>/.ns/chat.
// Pinned chats stay at the top of the list; archive/delete remove the row.
// The row menu (pin/archive/delete) follows the
// selector-popup pattern: rects are written while drawing and last frame's
// menu is resolved against this frame's click.
let g_chat_title = [i32: str](16)
let g_chat_pinned = [i32](16)
let g_chat_msg_count = [i32](16)
let g_chat_msg_text = [i32: str](1024)
let g_chat_msg_role = [i32](1024)
let g_chat_count: i32 = 0
let g_chat_archived: i32 = 0
let g_chat_store_loaded = false
let g_chat_persist = true
let g_chat_store_cursor: i32 = 0
let g_chat_store_ok = true
let g_chat_menu_chat: i32 = -1
let g_chat_menu_x: f64 = 0.0
let g_chat_menu_y: f64 = 0.0
let g_chat_menu_w: f64 = 0.0
let g_chat_menu_btn_x: f64 = 0.0
let g_chat_menu_btn_y: f64 = 0.0

// The UI face is configurable; the code grid remains monospaced so caret and
// selection columns stay exact even when the surrounding shell uses Sans UI.
fn FONT_MONO() i32 { return g_setting_font_family }
fn CODE_FONT() i32 { return 1 }

fn code_font_px() f64 {
    if g_setting_font_size == 0 {
        return 11.0
    }
    if g_setting_font_size == 2 {
        return 14.0
    }
    return 12.0
}
fn font_px() f64 { return code_font_px() }
fn code_line_h() f64 {
    if g_setting_font_size == 0 {
        return 18.0
    }
    if g_setting_font_size == 2 {
        return 24.0
    }
    return 20.0
}
fn code_wheel_scale() f64 { return 6.0 }
fn small_px() f64 {
    if g_setting_font_size == 2 {
        return 13.0
    }
    if g_setting_font_size == 0 {
        return 11.0
    }
    return 12.0
}

