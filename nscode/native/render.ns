// nscode/native/render.ns
// ---------------------------------------------------------------------------
// Active Nano Script renderer for the native NSCode shell. C owns only the
// low-level immediate-mode UI kernel; app/editor state and drawing live here.

use view
use ui
use editor
use workspace
use os
use std

fn MODE_CODE() i32 { return 0 }
fn MODE_AGENT() i32 { return 1 }
fn MODE_SETTINGS() i32 { return 2 }
fn UI_FOCUS_NONE() i32 { return 0 }
fn UI_FOCUS_MAIN_MENU() i32 { return 1 }
fn UI_FOCUS_POPUP() i32 { return 2 }
fn UI_FOCUS_CHAT_MENU() i32 { return 3 }

let g_mode: i32 = 1
let g_settings_return_mode: i32 = 1
