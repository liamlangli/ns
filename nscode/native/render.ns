// Agent view state: the conversation transcript (role + text per message), the
// codex-style composer (multi-line input, attachments, permission level and
// module selectors). String arrays are not
// supported by the runtime yet, so message/attachment text lives in i32-keyed
// dictionaries addressed by the parallel counters.
let g_msg_text = [i32: str](64)
let g_msg_role = [i32](64)
let g_msg_count: i32 = 0

let g_input_text = ""
let g_input_focus = true
let g_perm: i32 = 1
let g_module: i32 = 0
let g_attach_name = [i32: str](8)
let g_attach_count: i32 = 0
let g_attach_seq: i32 = 0
let g_running = false
let g_dialog_follow = false
let g_dialog_content_h: f64 = 0.0

// Composer/popup hit rects, written while drawing so click handling and the
// headless frame tests can address the controls without mirroring layout math.
let g_click_used = false
let g_pop_kind: i32 = 0
let g_cmp_x: f64 = 0.0
let g_cmp_y: f64 = 0.0
let g_cmp_w: f64 = 0.0
let g_cmp_h: f64 = 0.0
