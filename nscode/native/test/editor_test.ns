// nscode/native/test/editor_test.ns
// ---------------------------------------------------------------------------
// Headless checks for the document model in editor.ns: cursor placement,
// word/line selection, per-line selection spans, the syntax tokenizer and the
// typed-key character mapping. Runs on any platform (no view/gpu needed):
//
//   bin/ns test nscode/native/test/editor_test.ns

use std
use editor

let g_fail = 0

fn check(name: str, ok: bool) {
    if ok {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + unescape("\n"))
    }
}

fn check_i(name: str, got: i32, want: i32) {
    if got == want {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + " got " + itos(got) + " want " + itos(want) + unescape("\n"))
    }
}

fn check_s(name: str, got: str, want: str) {
    if got == want {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + " got [" + got + "] want [" + want + "]" + unescape("\n"))
    }
}

fn test_place_cursor() {
    load_str(unescape("fn main() {\n    print(42)\n}\n"))
    place_cursor(1, 4, false)
    check_i("place_cursor line", cur_line(), 1)
    check_i("place_cursor col", cur_col(), 4)
    place_cursor(1, 999, false)
    check_i("place_cursor clamps col", cur_col(), 13)
    place_cursor(99, 0, false)
    check_i("place_cursor clamps line", cur_line(), 3)
    place_cursor(-5, -5, false)
    check_i("place_cursor clamps to origin", cur_line() + cur_col(), 0)
}

fn test_click_selection() {
    load_str(unescape("fn main() {\n    print(42)\n}\n"))
    place_cursor(0, 3, false)
    place_cursor(1, 9, true)
    check("drag makes selection", has_selection())
    check_s("drag selected text", selected_text(), unescape("main() {\n    print"))
    check_i("line 0 sel begin", line_sel_begin(0), 3)
    check_i("line 0 sel end includes newline", line_sel_end(0), 12)
    check_i("line 1 sel begin", line_sel_begin(1), 0)
    check_i("line 1 sel end", line_sel_end(1), 9)
    check_i("line 2 no selection", line_sel_begin(2), -1)
    place_cursor(0, 3, false)
    check("click clears selection", has_selection() == false)
}

fn test_word_line_selection() {
    load_str(unescape("fn main() {\n    print(42)\n}\n"))
    select_word_at(1, 6)
    check_s("double click selects word", selected_text(), "print")
    select_word_at(0, 8)
    check_s("word fallback selects byte", selected_text(), ")")
    select_line(1)
    check_s("triple click selects line", selected_text(), unescape("    print(42)\n"))
}

fn test_editing_around_selection() {
    load_str(unescape("fn main() {\n    print(42)\n}\n"))
    select_word_at(1, 6)
    insert_str("log")
    check_s("typing replaces selection", line_text(1), "    log(42)")
    select_word_at(1, 5)
    delete_back()
    check_s("backspace deletes selection", line_text(1), "    (42)")
}

fn test_undo_redo() {
    load_str("abc")
    do_end(false)
    insert_str("d")
    insert_str("e")
    check_s("typing edits document", g_doc, "abcde")
    check("typing creates undo", can_undo())
    check("undo coalesced typing", undo())
    check_s("undo restores before typing", g_doc, "abc")
    check("redo typing", redo())
    check_s("redo restores typing", g_doc, "abcde")

    check("undo before branch", undo())
    insert_str("x")
    check_s("new edit starts branch", g_doc, "abcx")
    check("new edit clears redo", can_redo() == false)

    delete_back()
    delete_back()
    check_s("repeated backspace edits", g_doc, "ab")
    check("undo coalesced backspace", undo())
    check_s("backspace undo restores group", g_doc, "abcx")

    select_word_at(0, 1)
    insert_str("value")
    check_s("selection replacement edits", g_doc, "value")
    check("undo selection replacement", undo())
    check_s("selection replacement undo restores", g_doc, "abcx")
    check("redo selection replacement", redo())
    check_s("selection replacement redo restores", g_doc, "value")

    load_str("")
    insert_str("a")
    insert_newline()
    check_s("newline is separate edit", g_doc, unescape("a\n"))
    check("undo newline", undo())
    check_s("undo newline keeps typing", g_doc, "a")
    check("undo preceding typing", undo())
    check_s("second undo removes typing", g_doc, "")
}

fn expect_token(name: str, i: i32, start: i32, len: i32, kind: i32) {
    let ok = true
    if token_start(i) != start {
        ok = false
    }
    if token_len(i) != len {
        ok = false
    }
    if token_kind(i) != kind {
        ok = false
    }
    if ok {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        let got = itos(token_start(i)) + "/" + itos(token_len(i)) + "/" + itos(token_kind(i))
        let want = itos(start) + "/" + itos(len) + "/" + itos(kind)
        print("FAIL " + name + " got " + got + " want " + want + unescape("\n"))
    }
}

fn test_tokenizer() {
    // '"' cannot appear inside a double-quoted literal (no escape processing),
    // so the quoted "hi" is spliced in from a single-quoted literal.
    let src = "fn add(a: i32) i32 {\n    let x = 42 // answer\n    return " + '"hi"' + " + a\n}\n"
    load_str(unescape(src))

    let n0 = tokenize_line(0)
    check_i("line 0 token count", n0, 9)
    expect_token("fn keyword", 0, 0, 2, TK_KEYWORD())
    expect_token("add call", 1, 3, 3, TK_CALL())
    expect_token("open paren", 2, 6, 1, TK_PUNCT())
    expect_token("arg name", 3, 7, 1, TK_TEXT())
    expect_token("colon", 4, 8, 1, TK_PUNCT())
    expect_token("arg type", 5, 10, 3, TK_TYPE())
    expect_token("close paren", 6, 13, 1, TK_PUNCT())
    expect_token("ret type", 7, 15, 3, TK_TYPE())
    expect_token("open brace", 8, 19, 1, TK_PUNCT())

    let n1 = tokenize_line(1)
    check_i("line 1 token count", n1, 5)
    expect_token("let keyword", 0, 4, 3, TK_KEYWORD())
    expect_token("x ident", 1, 8, 1, TK_TEXT())
    expect_token("assign", 2, 10, 1, TK_PUNCT())
    expect_token("number", 3, 12, 2, TK_NUMBER())
    expect_token("comment to eol", 4, 15, 9, TK_COMMENT())

    let n2 = tokenize_line(2)
    check_i("line 2 token count", n2, 4)
    expect_token("return keyword", 0, 4, 6, TK_KEYWORD())
    expect_token("string literal", 1, 11, 4, TK_STRING())
    expect_token("plus", 2, 16, 1, TK_PUNCT())
    expect_token("a ident", 3, 18, 1, TK_TEXT())

    let cached = tokenize_line(2)
    check_i("token cache hit", cached, 4)
    place_cursor(2, 11, false)
    insert_str("x")
    let changed = tokenize_line(2)
    check_i("token cache invalidates after edit", changed, 5)
    expect_token("edited token is rescanned", 1, 11, 1, TK_TEXT())

    load_str("enum os_platform: u8 { unknown = 0, macos, }")
    let ne = tokenize_line(0)
    check("enum token count", ne >= 12)
    expect_token("enum keyword", 0, 0, 4, TK_KEYWORD())
    expect_token("enum type name", 1, 5, 11, TK_TYPE())
    expect_token("enum underlying type", 3, 18, 2, TK_TYPE())
    expect_token("enum first member", 5, 23, 7, TK_CONSTANT())
    expect_token("enum second member", 9, 36, 5, TK_CONSTANT())

    load_str(unescape("enum os_platform: u8 {\n    unknown = 0,\n    macos,\n}\nlet platform = os_platform.macos"))
    let multiline_first = tokenize_line(1)
    check("multiline enum first member tokens", multiline_first >= 3)
    expect_token("multiline enum first member", 0, 4, 7, TK_CONSTANT())
    let multiline_second = tokenize_line(2)
    check("multiline enum second member tokens", multiline_second >= 2)
    expect_token("multiline enum second member", 0, 4, 5, TK_CONSTANT())
    let qualified = tokenize_line(4)
    check("qualified enum access tokens", qualified >= 6)
    expect_token("qualified enum type", 3, 15, 11, TK_TYPE())
    expect_token("qualified enum member", 5, 27, 5, TK_CONSTANT())
}

fn test_key_char() {
    check_s("letter lowercase", key_char(65, false), "a")
    check_s("letter uppercase", key_char(65, true), "A")
    check_s("digit", key_char(57, false), "9")
    check_s("digit shifted", key_char(57, true), "(")
    check_s("space", key_char(32, false), " ")
    check_s("equal", key_char(61, false), "=")
    check_s("equal shifted", key_char(61, true), "+")
    check_s("quote shifted", key_char(39, true), '"')
    check_s("bracket shifted", key_char(91, true), "{")
    check_s("minus shifted", key_char(45, true), "_")
    check_s("non printable", key_char(262, false), "")
}

fn test_default_language() {
    set_syntax_language(1)
    check("typescript keyword set", is_keyword("const"))
    check("typescript type set", is_type_word("string"))
    set_syntax_language(2)
    check("python keyword set", is_keyword("def"))
    check("python type set", is_type_word("int"))
    load_str("x = 1 # note")
    let count = tokenize_line(0)
    check("python hash comment tokenized", count == 4)
    expect_token("python comment to eol", 3, 6, 6, TK_COMMENT())
    set_syntax_language(0)
}

fn main() i32 {
    test_place_cursor()
    test_click_selection()
    test_word_line_selection()
    test_editing_around_selection()
    test_undo_redo()
    test_tokenizer()
    test_key_char()
    test_default_language()
    if g_fail == 0 {
        print("editor_test: all passed" + unescape("\n"))
    } else {
        print("editor_test: " + itos(g_fail) + " FAILED" + unescape("\n"))
    }
    assert g_fail == 0
    return g_fail
}
