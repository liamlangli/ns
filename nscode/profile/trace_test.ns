// nscode/profile/trace_test.ns
// ---------------------------------------------------------------------------
// Headless checks for the trace parser in trace.ns. Runs on any platform
// (no view/gpu needed):
//
//   bin/ns test nscode/profile

use std
use trace

let g_fail: i32 = 0i

fn check(name: str, ok: bool) {
    if ok {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + unescape("\n"))
    }
}

fn check_i(name: str, got: i32, want: i32) {
    if got == want {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + " got " + itos(got) + " want " + itos(want) + unescape("\n"))
    }
}

fn check_s(name: str, got: str, want: str) {
    if got == want {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + " got [" + got + "] want [" + want + "]" + unescape("\n"))
    }
}

fn check_f(name: str, got: f64, want: f64) {
    let d = got - want
    if d < 0.0 { d = 0.0 - d }
    if d < 0.001 {
        print("ok   " + name + unescape("\n"))
    } else {
        g_fail = g_fail + 1
        print("FAIL " + name + unescape("\n"))
    }
}

// A five-event trace mirroring the writer's line-oriented layout, including
// an escaped quote in a name and a foreign event without args.depth.
fn sample() str {
    let nl = unescape("\n")
    let s = '{"traceEvents":[' + nl
    s = s + '{"name":"main","cat":"main","ph":"X","ts":0.000,"dur":100.000,"pid":1,"tid":1,"args":{"depth":0}},' + nl
    s = s + '{"name":"fib","cat":"main","ph":"X","ts":10.500,"dur":50.250,"pid":1,"tid":1,"args":{"depth":1}},' + nl
    s = s + '{"name":"print","cat":"std","ph":"X","ts":12.000,"dur":1.500,"pid":1,"tid":1,"args":{"depth":2}},' + nl
    s = s + '{"name":"he\"llo","cat":"main","ph":"X","ts":90.000,"dur":5.000,"pid":1,"tid":1,"args":{"depth":1}},' + nl
    s = s + '{"name":"nodepth","cat":"x","ph":"X","ts":200.000,"dur":5.000,"pid":1,"tid":1}' + nl
    s = s + "]}" + nl
    return s
}

fn test_parse() {
    let n = trace_load(sample())
    check_i("event count", n, 5)
    check_i("trace_count", trace_count(), 5)
    check_s("name 0", ev_name(0), "main")
    check_s("name 1", ev_name(1), "fib")
    check_s("cat 2", ev_cat(2), "std")
    check_s("escaped quote name", ev_name(3), "he" + '"' + "llo")
    check_f("ts 1", ev_ts(1), 10.5)
    check_f("dur 1", ev_dur(1), 50.25)
    check_f("dur 2", ev_dur(2), 1.5)
    check_i("depth 0", ev_depth(0), 0)
    check_i("depth 2", ev_depth(2), 2)
    check_i("missing depth defaults to 0", ev_depth(4), 0)
    check_f("trace end", trace_end(), 205.0)
    check_i("max depth", trace_max_depth(), 2)
    check("not truncated", trace_truncated() == false)
    check_s("out of range name", ev_name(99), "")
}

fn test_reload() {
    let nl = unescape("\n")
    let one = '{"name":"solo","cat":"main","ph":"X","ts":1.000,"dur":2.000,"pid":1,"tid":1,"args":{"depth":0}}' + nl
    let n = trace_load(one)
    check_i("reload count", n, 1)
    check_s("reload name", ev_name(0), "solo")
    check_f("reload end", trace_end(), 3.0)
    check_i("reload max depth", trace_max_depth(), 0)
}

fn test_fmt() {
    check_s("fmt us", fmt_us(1.5), "1.5us")
    check_s("fmt ms", fmt_us(1500.0), "1.5ms")
    check_s("fmt s", fmt_us(2000000.0), "2.0s")
    check_s("itos", itos(1204), "1204")
    check_s("itos zero", itos(0), "0")
}

fn main() i32 {
    test_parse()
    test_reload()
    test_fmt()
    if g_fail == 0 {
        print("trace_test: all passed" + unescape("\n"))
    } else {
        print("trace_test: " + itos(g_fail) + " FAILED" + unescape("\n"))
    }
    assert g_fail == 0
    return 0
}
