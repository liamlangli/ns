// Vertex-layout reflection and fn-based pipeline creation over the gpu
// scalar-ID API. The reflection intrinsics are VM-side and exact on every
// platform. gpu_create_pipeline transpiles the fn pair in the VM and reaches
// the native backend; without a requested GPU device the returned id is
// backend-defined (0 where shaders cannot be built headless), so only the
// call path is exercised here.
use std
use simd
use gpu

struct vertex_data { position: float3, uv: float2, weight: f32 }
struct fragment_input { position: float4, uv: float2 }

fn vs_main(data: vertex_data) fragment_input {
    let pos = data.position
    return fragment_input {
        position: float4 { x: pos.x, y: pos.y, z: pos.z, w: data.weight },
        uv: data.uv,
    }
}

fn fs_main(data: fragment_input) float4 {
    let uv = data.uv
    return float4 { x: uv.x, y: uv.y, z: 0.0, w: 1.0 }
}

assert(shader_vertex_stride(vs_main) == 24)
assert(shader_vertex_attr_count(vs_main) == 3)
assert(shader_vertex_attr_offset(vs_main, 0) == 0)
assert(shader_vertex_attr_offset(vs_main, 1) == 12)
assert(shader_vertex_attr_offset(vs_main, 2) == 20)
assert(shader_vertex_attr_size(vs_main, 0) == 3)
assert(shader_vertex_attr_size(vs_main, 1) == 2)
assert(shader_vertex_attr_size(vs_main, 2) == 1)

let pipeline = gpu_create_pipeline(vs_main, fs_main)
gpu_destroy_pipeline_id(pipeline)
